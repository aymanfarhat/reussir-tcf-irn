DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

POSTGRES_DB=tcf_irn
POSTGRES_USER=tcf_irn
POSTGRES_PASSWORD=tcf_irn
DATABASE_URL=postgres://tcf_irn:tcf_irn@db:5432/tcf_irn
DATABASE_CONN_MAX_AGE=60

REDIS_URL=redis://redis:6379/0
DJANGO_CACHE_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_CONCURRENCY=2

GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=300
GUNICORN_MAX_REQUESTS=300
GUNICORN_MAX_REQUESTS_JITTER=50

DJANGO_INTERNAL_BASE=http://web:8000
DJANGO_PUBLIC_BASE=http://localhost:8000

OPENAI_API_KEY=
OPENAI_GRADING_MODEL=gpt-5.5
OPENAI_IMPROVEMENT_MODEL=gpt-5.5
OPENAI_AUDIO_GRADING_MODEL=gpt-audio
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_LANGUAGE=fr
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_FORMAT=mp3
OPENAI_TTS_INSTRUCTIONS=Speak clearly in French as a neutral TCF IRN examiner. Use a calm, natural pace.

DOMAIN_NAME=localhost
ACME_EMAIL=admin@example.com
QUESTION_BANK_PATH=/product_research/question_bank.json
