    {
      "id": "q043",
      "section": "expression_ecrite",
      "task_number": 5,
      "task_id": "written_task_2",
      "task_type_fr": "Récit / expérience",
      "question": "Vous répondez à Sofia. Vous lui racontez comment s'est passée votre dernière démarche administrative importante et ce qui a été facile ou difficile.",
      "themes": ["démarches", "administration"],
      "addressee": "Sofia",
      "register": "informel (tu)",
      "timing": { "suggested_duration_minutes": 9, "section_total_minutes": 30 },
      "expected_response": {
        "word_count": { "min": 40, "max": 90, "target": 80 },
        "structure": [
          "Salutation à Sofia",
          "Démarche identifiée",
          "Étapes principales",
          "Ce qui a été facile / difficile",
          "Bilan"
        ],
        "reference_answer": "Salut Sofia,\nLe mois dernier, j'ai renouvelé mon titre de séjour. Au début, prendre le rendez-vous en ligne a été facile, le site était plutôt bien fait. En revanche, rassembler tous les documents a été assez compliqué : il fallait des justificatifs récents et une attestation de mon employeur. Le rendez-vous en préfecture s'est bien passé. Au final, je suis soulagée. Bisous, Nora.",
        "reference_answer_word_count": 64,
        "alternative_answer": "Coucou Sofia,\nLa semaine dernière, j'ai fait ma déclaration d'impôts. Connexion à mon espace personnel : facile, j'ai utilisé FranceConnect. Vérifier les revenus pré-remplis : sans problème. Par contre, ajouter mes frais professionnels et comprendre certaines cases m'a pris du temps. Heureusement, le service en ligne propose une assistance par chat. Au final, c'était plus simple que je ne pensais. À bientôt, Karim.",
        "alternative_answer_word_count": 61,
        "key_elements_to_cover": [
          "Démarche identifiée",
          "Au moins deux étapes",
          "Ce qui a été facile",
          "Ce qui a été difficile",
          "Bilan personnel"
        ],
        "key_vocabulary": ["démarche", "renouveler", "titre de séjour", "déclaration", "justificatif", "préfecture", "rendez-vous", "soulagé(e)"],
        "key_grammar": ["Passé composé", "Imparfait", "Opposition (en revanche, par contre)", "Falloir + infinitif"]
      },
