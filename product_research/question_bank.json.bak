      ]
    },
    {
      "id": "q047",
      "section": "expression_ecrite",
      "task_number": 5,
      "task_id": "written_task_2",
      "task_type_fr": "Récit / expérience",
      "question": "Vous répondez à Anna. Vous lui racontez une panne de téléphone, d'ordinateur ou d'Internet que vous avez eue et comment vous avez résolu le problème.",
      "themes": ["technologie", "résolution de problèmes"],
      "addressee": "Anna",
      "register": "informel (tu)",
      "timing": { "suggested_duration_minutes": 9, "section_total_minutes": 30 },
      "expected_response": {
        "word_count": { "min": 40, "max": 90, "target": 80 },
        "structure": [
          "Salutation à Anna",
          "Description du problème",
          "Étapes de résolution",
          "Issue (solution trouvée)",
          "Leçon ou anecdote"
        ],
        "reference_answer": "Salut Anna,\nLa semaine dernière, mon ordinateur s'est éteint subitement et ne se rallumait plus. J'étais en plein télétravail, donc panique totale. J'ai d'abord vérifié l'alimentation et le câble, sans succès. Ensuite, j'ai appelé un ami informaticien qui m'a guidée pas à pas. Au final, c'était la batterie qui était morte. J'en ai commandé une neuve en ligne. Bisous, Léa.",
        "reference_answer_word_count": 63,
        "alternative_answer": "Coucou Anna,\nMardi soir, mon Internet est tombé en panne juste avant un cours en ligne. J'ai d'abord redémarré la box, puis j'ai contacté le support technique. L'opérateur m'a fait faire plusieurs manipulations à distance. Finalement, c'était un problème de fibre dans mon immeuble. Un technicien est venu le lendemain. Quelle galère, mais tout est rentré dans l'ordre. Bisous, Karim.",
        "alternative_answer_word_count": 62,
        "key_elements_to_cover": [
          "Problème identifié",
          "Au moins deux étapes de résolution",
          "Solution finale",
          "Sentiment ou réflexion",
          "Salutation et signature"
        ],
        "key_vocabulary": ["panne", "tomber en panne", "redémarrer", "support technique", "alimentation", "résoudre", "manipulation", "technicien"],
        "key_grammar": ["Passé composé", "Imparfait pour le contexte", "Connecteurs temporels (d'abord, ensuite, finalement)", "Pronoms COD/COI"]
      },
      "evaluation_focus": [
        "Récit chronologique clair",
        "Vocabulaire technique de base",
        "Émotion exprimée",
        "Compte de mots respecté"
      ]
