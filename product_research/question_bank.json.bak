        "Chronologie claire",
        "Émotion exprimée",
        "Compte de mots respecté"
      ]
    },
    {
      "id": "q042",
      "section": "expression_ecrite",
      "task_number": 5,
      "task_id": "written_task_2",
      "task_type_fr": "Récit / expérience",
      "question": "Vous répondez à Clara. Vous lui racontez votre expérience dans un nouveau restaurant, café ou marché de votre ville.",
