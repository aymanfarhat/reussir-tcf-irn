      },
      "evaluation_focus": [
        "Modes alternatifs concrets",
        "Chronologie claire",
        "Bilan personnel",
        "Compte de mots respecté"
      ]
    },
    {
      "id": "q046",
      "section": "expression_ecrite",
      "task_number": 5,
      "task_id": "written_task_2",
      "task_type_fr": "Récit / expérience",
      "question": "Vous répondez à Mehdi. Vous lui racontez une sortie culturelle récente : exposition, concert, film, festival ou visite guidée.",
