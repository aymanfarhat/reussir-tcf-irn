{
  "metadata": {
    "exam_name": "TCF IRN",
    "exam_full_name": "Test de Connaissance du Français pour l'Intégration, la Résidence et la Nationalité",
    "issuing_organization": "France Éducation international",
    "version": "1.0.0",
    "valid_from": "2025-05-12",
    "naturalization_requirement_from": "2026-01-01",
    "target_level": "B2",
    "scope": "Expression orale and Expression écrite only",
    "language": "fr",
    "total_questions": 60,
    "questions_per_task_type": 10
  },
  "scoring": {
    "max_score_per_section": 20,
    "evaluation_method": "Each oral and written production is independently corrected by two graders. Each grader assigns a CEFR level (A1 to C2) to each of the three tasks of the section. A non-public formula combines the per-task levels into the final 0-20 score and corresponding CEFR level for the section.",
    "level_bands": [
      { "level": "A1", "score_min": 0, "score_max": 3, "midpoint": 1.5 },
      { "level": "A2", "score_min": 4, "score_max": 6, "midpoint": 5.0 },
      { "level": "B1", "score_min": 7, "score_max": 9, "midpoint": 8.0 },
      { "level": "B2", "score_min": 10, "score_max": 13, "midpoint": 11.5 },
      { "level": "C1", "score_min": 14, "score_max": 17, "midpoint": 15.5 },
      { "level": "C2", "score_min": 18, "score_max": 20, "midpoint": 19.0 }
    ],
    "target_safe_score": 12,
    "target_safe_score_rationale": "Aiming for at least 12/20 with no single task clearly below B2 secures the B2 result needed for naturalization (B2 zone is 10-13/20, so 12 leaves a margin against grader variance).",
    "automatic_failure_conditions": [
      "Word count not respected (especially in written tasks)",
      "Off-topic response (hors-sujet)",
      "A required task is missing",
      "The production is incomplete",
      "These conditions can drive a section result to 'A1 non atteint'"
    ],
    "scoring_aggregation_for_app": {
      "per_dimension_score_range": [0, 20],
      "task_score_formula": "Average of all dimension scores for that task, rounded to 0.5",
      "section_score_formula": "Weighted average of the 3 task scores (equal weights as a sensible default; the official formula is non-public)",
      "level_assignment": "Map the final section score to a level band using level_bands"
    }
  },
  "grading_dimensions": [
    {
      "id": "task_realization",
      "name_fr": "Réalisation de la tâche",
      "name_en": "Task completion",
      "description": "Does the candidate fully address the prompt, stay on topic, respect the situation, and deliver all the elements explicitly or implicitly required?",
      "applies_to": ["expression_orale", "expression_ecrite"],
      "weight_hint": "Highest priority. A weak task realization caps the overall score regardless of language quality."
    },
    {
      "id": "coherence_structure",
      "name_fr": "Cohérence et cohésion",
      "name_en": "Coherence and structure",
      "description": "Are the ideas organized, sequenced logically, linked with appropriate connectors, and easy to follow from start to finish?",
      "applies_to": ["expression_orale", "expression_ecrite"]
    },
    {
      "id": "sociolinguistic_appropriateness",
      "name_fr": "Adéquation sociolinguistique",
      "name_en": "Sociolinguistic appropriateness",
      "description": "Is the register adapted to the situation, the interlocutor, and the channel (face-to-face exam, friendly message, public forum, etc.)? Are politeness markers, greetings, and closings used appropriately?",
      "applies_to": ["expression_orale", "expression_ecrite"]
    },
    {
      "id": "lexicon",
      "name_fr": "Lexique",
      "name_en": "Vocabulary",
      "description": "Is the vocabulary varied, precise, and adapted to the topic? Are repetitions limited? Can the candidate paraphrase when a word is missing?",
      "applies_to": ["expression_orale", "expression_ecrite"]
    },
    {
      "id": "morphosyntax",
      "name_fr": "Morphosyntaxe",
      "name_en": "Morphosyntax (grammar)",
      "description": "Are common B2 structures controlled (tenses, agreements, prepositions, relative clauses, subordination)? Are errors non-blocking for understanding?",
      "applies_to": ["expression_orale", "expression_ecrite"]
    },
    {
      "id": "phonology",
      "name_fr": "Phonologie",
      "name_en": "Pronunciation and prosody",
      "description": "Is the pronunciation intelligible? Are the rhythm, intonation, and liaison patterns sufficient to support meaning? Is the accent non-disruptive for an unprepared listener?",
      "applies_to": ["expression_orale"]
    },
    {
      "id": "orthography",
      "name_fr": "Orthographe",
      "name_en": "Spelling",
      "description": "Are spelling and basic punctuation sufficiently controlled to not disrupt reading?",
      "applies_to": ["expression_ecrite"]
    }
  ],
  "generic_level_descriptors": {
    "task_realization": {
      "A1": "Almost no response, off-topic, or so brief that the task is not realized.",
      "A2": "Partial response, several required elements missing or only superficially addressed.",
      "B1": "Most required elements addressed but some are weak, missing or only listed without development.",
      "B2": "All required elements addressed clearly and with adequate development. Stays on topic and respects the situation throughout.",
      "C1": "Required elements developed in depth with relevant detail, anticipation of objections, and refined adaptation to the situation.",
      "C2": "Task fully and skilfully realized with subtle, targeted choices and effortless adaptation to the situation."
    },
    "coherence_structure": {
      "A1": "Juxtaposed words or sentences without visible link.",
      "A2": "Simple sentences linked with a few basic connectors (et, mais, parce que). Order can be unclear.",
      "B1": "Generally coherent sequence with simple connectors. Some abrupt jumps possible.",
      "B2": "Clear progression with appropriate connectors (d'abord, ensuite, par contre, en effet, donc, par exemple, en conclusion). Easy to follow.",
      "C1": "Well-structured discourse with varied connectors, clear paragraphing or oral signposting, smooth transitions.",
      "C2": "Tightly organized discourse with sophisticated cohesion devices used naturally."
    },
    "sociolinguistic_appropriateness": {
      "A1": "Register inappropriate or absent. No politeness markers.",
      "A2": "Basic politeness present but register sometimes mismatched.",
      "B1": "Generally appropriate register but some inconsistencies.",
      "B2": "Register clearly adapted to the interlocutor and channel. Politeness markers, opening and closing formulas correctly used.",
      "C1": "Confident handling of register, including nuance and tone shifts.",
      "C2": "Fully natural sociolinguistic adaptation, including humour or implicit meaning when relevant."
    },
    "lexicon": {
      "A1": "Very limited vocabulary, frequent gaps that block meaning.",
      "A2": "Basic vocabulary sufficient for predictable topics but many repetitions.",
      "B1": "Adequate vocabulary on familiar topics, occasional imprecision but meaning carries through.",
      "B2": "Range of vocabulary sufficient on a wide range of topics. Limited repetitions. Can paraphrase when a word is missing. Some imprecisions remain but never block understanding.",
      "C1": "Broad and precise vocabulary with idiomatic expressions and topic-specific terms.",
      "C2": "Very broad and precise vocabulary including idiomatic and colloquial expressions used appropriately."
    },
    "morphosyntax": {
      "A1": "Only memorized fragments. Errors block understanding.",
      "A2": "Simple structures. Frequent errors but meaning often gets across.",
      "B1": "Reasonably accurate use of frequent patterns. Errors when attempting more complex structures.",
      "B2": "Good control of common B2 structures (past tenses, conditional, subjunctive after frequent triggers, relative clauses, complex sentences). Errors are present but non-blocking.",
      "C1": "High degree of grammatical control. Errors are rare and self-corrected.",
      "C2": "Consistent grammatical control of complex language even when attention is elsewhere."
    },
    "phonology": {
      "A1": "Pronunciation often unintelligible.",
      "A2": "Pronunciation requires effort to understand.",
      "B1": "Pronunciation generally clear despite a noticeable accent and occasional mispronunciations.",
      "B2": "Clear and intelligible pronunciation. Accent may be noticeable but does not disrupt understanding. Intonation supports meaning.",
      "C1": "Varied intonation and clear articulation, very minor influence of L1 accent.",
      "C2": "Pronunciation as easy to follow as a native speaker's, with full prosodic control."
    },
    "orthography": {
      "A1": "Spelling often blocks reading.",
      "A2": "Many basic spelling errors but words are mostly recognizable.",
      "B1": "Spelling generally correct on frequent words. Errors on agreements and verb endings.",
      "B2": "Spelling and punctuation sufficiently controlled. Errors remain (especially on verb endings and agreements) but never block reading.",
      "C1": "Few spelling errors, good control of punctuation.",
      "C2": "Almost no spelling or punctuation errors."
    }
  },
  "sections": [
    {
      "id": "expression_orale",
      "name_fr": "Expression orale",
      "name_en": "Oral expression",
      "total_duration_minutes": 10,
      "preparation_time_minutes": 0,
      "format": "Face-to-face with an examiner; the production is recorded.",
      "number_of_tasks": 3,
      "section_notes": [
        "No preparation time at all.",
        "The examiner can interrupt a memorized presentation to force a more spontaneous answer.",
        "In the actual exam, tasks 2 and 3 are drawn from a pool of 5 prompts each; the examiner picks one."
      ],
      "tasks": [
        {
          "task_number": 1,
          "id": "oral_task_1",
          "name_fr": "Présentation / questions personnelles",
          "name_en": "Directed interview / personal questions",
          "duration_minutes": 3,
          "duration_range_minutes": [2, 3],
          "preparation_time_minutes": 0,
          "format": "Directed interview: examiner asks questions and follow-ups (relances).",
          "objective": "Talk about yourself, your situation, and your daily life in a way that is personal, developed, and spontaneous (not a memorized script).",
          "expected_response_word_count": { "min": 220, "ideal": 280, "max": 360 },
          "expected_response_word_count_rationale": "At ~95-115 spoken words/minute for a B2 candidate, 3 minutes of effective speaking time corresponds to roughly 280-340 words. The lower bound accounts for examiner relances inside the 3 minutes.",
          "skills_assessed": [
            "Speak about oneself spontaneously",
            "Develop ideas with personal detail",
            "Respond to follow-up questions",
            "Sustain a short conversational exchange"
          ],
          "expected_structure": [
            "Direct, personal opening that addresses the question",
            "Two or three concrete details (facts, examples, reasons)",
            "A nuance, a contrast, or a personal feeling",
            "A closing that opens to a follow-up (project, wish, current situation)"
          ],
          "required_elements": [
            "Stay personal and concrete (no recited bio)",
            "Provide at least 3 specific pieces of information",
            "Use at least 2 different verb tenses (present + past or present + future)",
            "Include connectors (par exemple, en effet, par contre, donc)"
          ],
          "common_topics": ["identité", "famille", "études", "travail", "habitudes", "goûts", "loisirs", "logement", "déplacements", "projets"],
          "examiner_behavior": "May ask follow-up questions, ask for clarification, or interrupt a recited presentation.",
          "strategy_tips": [
            "Treat the prompt as a conversation starter, not a speech.",
            "Use 'parce que', 'par exemple', 'en fait' to develop each idea.",
            "Stay alert for relances and answer them directly without restarting your script."
          ],
          "common_pitfalls": [
            "Reciting a memorized self-introduction.",
            "Listing facts without developing them.",
            "Speaking too briefly and waiting for the next question.",
            "Going off-topic to recycle pre-prepared content."
          ],
          "rubric_dimensions": ["task_realization", "coherence_structure", "sociolinguistic_appropriateness", "lexicon", "morphosyntax", "phonology"],
          "task_specific_rubric": {
            "task_realization": {
              "B2_target": "Answers personally and concretely; provides 3+ pieces of information; develops with reasons or examples; reacts naturally to relances.",
              "common_below_B2": "Recited presentation, listing without development, very short answers that force the examiner to fill the time."
            },
            "coherence_structure": {
              "B2_target": "Ideas linked with appropriate connectors; clear progression from main answer to detail to nuance.",
              "common_below_B2": "Disconnected sentences; only 'et' and 'mais' as connectors."
            },
            "sociolinguistic_appropriateness": {
              "B2_target": "Polite tone with the examiner, neither too familiar nor over-formal; natural use of 'vous'.",
              "common_below_B2": "Confusion between tu/vous; absence of polite framing."
            },
            "lexicon": {
              "B2_target": "Varied vocabulary on personal life, work, hobbies; can paraphrase a missing word.",
              "common_below_B2": "Heavy repetition of 'bien', 'beaucoup', 'choses'."
            },
            "morphosyntax": {
              "B2_target": "Present, passé composé, imparfait, futur proche/simple, conditional all available; subordinate clauses with 'parce que', 'quand', 'si'.",
              "common_below_B2": "Only present tense; agreement errors that block meaning."
            },
            "phonology": {
              "B2_target": "Clear and intelligible pronunciation; accent does not disrupt understanding.",
              "common_below_B2": "Mispronunciations or hesitations that force the examiner to ask again."
            }
          }
        },
        {
          "task_number": 2,
          "id": "oral_task_2",
          "name_fr": "Interaction / jeu de rôle",
          "name_en": "Situational interaction / role play",
          "duration_minutes": 3.5,
          "duration_range_minutes": [3, 4],
          "preparation_time_minutes": 0,
          "format": "Role play: the examiner plays a defined role (agent, vendor, secretary). The candidate must obtain information, explain needs, and react.",
          "objective": "Negotiate, ask precise questions, explain needs, compare options, and react to the examiner's answers in a real-life situation.",
          "expected_response_word_count": { "min": 240, "ideal": 320, "max": 420 },
          "expected_response_word_count_rationale": "3 min 30 of interactive speaking. Includes the examiner's turns, so the candidate produces ~250-330 words spread across multiple exchanges.",
          "skills_assessed": [
            "Open and close an interaction politely",
            "Ask precise questions",
            "Explain needs, preferences, and constraints",
            "Compare and prioritize options",
            "Reformulate when not understood",
            "React to the interlocutor's answers"
          ],
          "expected_structure": [
            "Opening (greeting + statement of the need)",
            "Description of the situation (context, constraints, preferences)",
            "Two to four precise questions",
            "Reaction to the answers (comparison, preference, reformulation)",
            "Conclusion (decision, next step, thanks, closing)"
          ],
          "required_elements": [
            "At least 3 precise questions, not just yes/no",
            "Explicit constraints (budget, time, location, preferences)",
            "Comparison or hierarchy between options",
            "A clear conclusion (chosen option, next step, polite closing)"
          ],
          "examiner_behavior": "Plays the role indicated in the prompt; provides information that must be reacted to; may add complications.",
          "strategy_tips": [
            "Open with a greeting and a one-sentence statement of the need.",
            "Front-load constraints so the examiner can give targeted information.",
            "Listen actively; reformulate before deciding.",
            "Always end on a clear conclusion or next step."
          ],
          "common_pitfalls": [
            "Monologuing instead of interacting.",
            "Asking only yes/no questions.",
            "Not stating constraints, then being offered irrelevant options.",
            "Never concluding the exchange."
          ],
          "rubric_dimensions": ["task_realization", "coherence_structure", "sociolinguistic_appropriateness", "lexicon", "morphosyntax", "phonology"],
          "task_specific_rubric": {
            "task_realization": {
              "B2_target": "Explains needs clearly, asks 3+ precise questions, compares options, reacts to answers, concludes the exchange.",
              "common_below_B2": "Vague needs, only yes/no questions, no reaction to examiner answers, no conclusion."
            },
            "coherence_structure": {
              "B2_target": "Logical flow from need to questions to comparison to decision; transitions feel natural.",
              "common_below_B2": "Random order of questions; no visible link between turns."
            },
            "sociolinguistic_appropriateness": {
              "B2_target": "Polite formulas appropriate to a customer/professional exchange (Bonjour, je voudrais, est-ce que vous pourriez, merci, au revoir).",
              "common_below_B2": "Direct demands without polite framing; inappropriate familiarity."
            },
            "lexicon": {
              "B2_target": "Vocabulary specific to the situation (logement, formation, voyage, soin, mobilité); precise descriptors and quantifiers.",
              "common_below_B2": "Generic vocabulary that does not fit the situation."
            },
            "morphosyntax": {
              "B2_target": "Polite conditional ('je voudrais', 'pourriez-vous'), interrogative structures (inversion or 'est-ce que'), comparison structures.",
              "common_below_B2": "Only declarative sentences with rising intonation as questions."
            },
            "phonology": {
              "B2_target": "Intonation supports the function of each turn (question, request, conclusion).",
              "common_below_B2": "Monotone delivery that obscures whether a turn is a question or a statement."
            }
          }
        },
        {
          "task_number": 3,
          "id": "oral_task_3",
          "name_fr": "Opinion / prise de position",
          "name_en": "Expressing and defending an opinion",
          "duration_minutes": 3.5,
          "duration_range_minutes": [3, 4],
          "preparation_time_minutes": 0,
          "format": "Continuous monologue: the candidate states and defends a position on a familiar topic.",
          "objective": "Express a clear opinion, defend it with arguments and examples, nuance it, and conclude.",
          "expected_response_word_count": { "min": 280, "ideal": 340, "max": 420 },
          "expected_response_word_count_rationale": "3 min 30 of mostly continuous speaking. ~95-120 words/minute → 330-420 words for a fluent B2 candidate.",
          "skills_assessed": [
            "State a clear position",
            "Develop arguments with reasoning",
            "Illustrate with examples",
            "Introduce a nuance or concession",
            "Conclude convincingly"
          ],
          "expected_structure": [
            "Brief introduction reformulating the question",
            "Clear statement of opinion",
            "First argument + example",
            "Second argument + example",
            "Nuance, concession, or counter-point",
            "Short conclusion"
          ],
          "required_elements": [
            "Explicit position taken (not 'it depends' alone)",
            "At least 2 distinct arguments",
            "At least 1 concrete example",
            "A nuance or concession ('cependant', 'malgré tout', 'il est vrai que')",
            "A short conclusion"
          ],
          "examiner_behavior": "Listens; may ask one or two follow-up questions at the end if time remains.",
          "strategy_tips": [
            "Choose a side quickly even if you see both. Nuance comes later.",
            "Map two distinct arguments before starting the second one (don't repeat the first in different words).",
            "Anchor each argument in a concrete example from daily life.",
            "Use connectors as audible signposts: 'd'abord', 'ensuite', 'par exemple', 'cependant', 'pour conclure'."
          ],
          "common_pitfalls": [
            "Avoiding a position with 'it depends'.",
            "Two arguments that are actually the same.",
            "Examples that are too abstract or hypothetical.",
            "No conclusion: stops mid-thought when time runs out."
          ],
          "rubric_dimensions": ["task_realization", "coherence_structure", "sociolinguistic_appropriateness", "lexicon", "morphosyntax", "phonology"],
          "task_specific_rubric": {
            "task_realization": {
              "B2_target": "Clear opinion, 2 distinct arguments, at least 1 example, a nuance, a conclusion.",
              "common_below_B2": "Position never stated; arguments collapse into one; no nuance; abrupt ending."
            },
            "coherence_structure": {
              "B2_target": "Audible plan with connectors signposting each move (introduction, arguments, nuance, conclusion).",
              "common_below_B2": "Stream of opinions with no visible plan."
            },
            "sociolinguistic_appropriateness": {
              "B2_target": "Polite hedges ('à mon avis', 'selon moi', 'il me semble que') and a respectful tone even on sensitive topics.",
              "common_below_B2": "Categorical statements with no hedging; tone too aggressive or too tentative."
            },
            "lexicon": {
              "B2_target": "Topic-specific vocabulary (santé, environnement, numérique, éducation) and connectors of argumentation.",
              "common_below_B2": "Repetition of 'bien', 'mauvais', 'bon'; few topic-specific words."
            },
            "morphosyntax": {
              "B2_target": "Subjunctive after 'il faut que', 'bien que'; conditional for opinions; complex sentences.",
              "common_below_B2": "Only simple sentences; absent subjunctive even where strongly expected."
            },
            "phonology": {
              "B2_target": "Intonation shapes the argumentation; clear emphasis on key words.",
              "common_below_B2": "Monotone delivery; key arguments not vocally highlighted."
            }
          }
        }
      ]
    },
    {
      "id": "expression_ecrite",
      "name_fr": "Expression écrite",
      "name_en": "Written expression",
      "total_duration_minutes": 30,
      "preparation_time_minutes": 0,
      "format": "Three short writing tasks completed at a computer. The candidate manages their own time within the 30 minutes.",
      "number_of_tasks": 3,
      "section_notes": [
        "Word counts are strict and contribute to the rating.",
        "TCF IRN does not require long 150-180 word essays. The format is deliberately short.",
        "Off-topic, missing tasks, or word count violations can drive the section to 'A1 non atteint'."
      ],
      "tasks": [
        {
          "task_number": 4,
          "id": "written_task_1",
          "name_fr": "Message court (description)",
          "name_en": "Short descriptive message",
          "suggested_duration_minutes": 7,
          "word_count": { "min": 30, "max": 60, "target": 50 },
          "format": "Reply to a short message from a friend or contact. Describe a person, place, object, or service.",
          "objective": "Produce a short, accurate descriptive message that addresses every element requested in the prompt, in a register adapted to the addressee.",
          "expected_structure": [
            "Greeting addressed to the named contact",
            "Direct mention of what is being described",
            "2 to 3 concrete attributes (drawn from the prompt's bullet list)",
            "A short personal recommendation or wrap-up",
            "Closing formula"
          ],
          "required_elements": [
            "Address the named addressee explicitly",
            "Cover EVERY descriptor mentioned in the prompt (e.g. age, profession, character, interests)",
            "Stay within 30-60 words",
            "Use a friendly informal register (tu) unless the prompt suggests otherwise",
            "Sign off"
          ],
          "strategy_tips": [
            "Underline each descriptor in the prompt and tick them as you write.",
            "Write a draft first, then tighten until you are inside 30-60 words.",
            "Keep sentences short and clear; precision beats sophistication."
          ],
          "common_pitfalls": [
            "Skipping a descriptor from the bullet list.",
            "Writing fewer than 30 words (automatic penalty).",
            "Writing more than 60 words and losing focus.",
            "Confusing register (formal vous when the prompt names a friend)."
          ],
          "rubric_dimensions": ["task_realization", "coherence_structure", "sociolinguistic_appropriateness", "lexicon", "morphosyntax", "orthography"],
          "task_specific_rubric": {
            "task_realization": {
              "B2_target": "Every descriptor from the prompt is covered with concrete information; word count respected; addressee named.",
              "common_below_B2": "One or more descriptors missing; out of word count; vague description."
            },
            "coherence_structure": {
              "B2_target": "Greeting → topic → attributes → recommendation → closing, fluent within 50 words.",
              "common_below_B2": "List-like format; no greeting or no closing."
            },
            "sociolinguistic_appropriateness": {
              "B2_target": "Friendly tone with appropriate informal markers ('Salut', 'Coucou', 'À bientôt').",
              "common_below_B2": "Over-formal tone with 'Madame, Monsieur' for a friend."
            },
            "lexicon": {
              "B2_target": "Concrete descriptive vocabulary (adjectives of character, place, function); avoid empty words.",
              "common_below_B2": "Repeated 'bien', 'sympa', 'cool' without specifics."
            },
            "morphosyntax": {
              "B2_target": "Present tense well controlled; agreement of adjectives; relative clauses with 'qui', 'que'.",
              "common_below_B2": "Repeated agreement errors on adjectives; very simple sentences only."
            },
            "orthography": {
              "B2_target": "Spelling sufficient for clean reading; standard punctuation.",
              "common_below_B2": "Multiple spelling errors per sentence; missing accents that change meaning."
            }
          }
        },
        {
          "task_number": 5,
          "id": "written_task_2",
          "name_fr": "Récit / expérience",
          "name_en": "Short narrative / personal experience",
          "suggested_duration_minutes": 9,
          "word_count": { "min": 40, "max": 90, "target": 75 },
          "format": "Reply to a short message from a friend. Tell about a recent experience or daily-life event.",
          "objective": "Tell a short story in the past, with clear chronology, concrete detail, and a personal reaction.",
          "expected_structure": [
            "Greeting and brief framing",
            "Time marker (la semaine dernière, hier, il y a quelques jours)",
            "Sequence of events in chronological order (au début, ensuite, finalement)",
            "One concrete detail or anecdote",
            "Personal reaction, feeling, or consequence",
            "Closing formula"
          ],
          "required_elements": [
            "Use the past (passé composé + imparfait)",
            "At least one explicit time marker",
            "At least 3 ordered events",
            "A personal reaction or consequence",
            "Stay within 40-90 words"
          ],
          "strategy_tips": [
            "Pick a real (or realistic) event you can describe simply; the topic is less important than the structure.",
            "Use 'au début / ensuite / finalement' to make the chronology obvious.",
            "Choose one vivid detail and skip the rest.",
            "End on a feeling or a takeaway."
          ],
          "common_pitfalls": [
            "All passé composé and no imparfait (or the opposite).",
            "No time markers, so the order of events is unclear.",
            "Too many events superficially listed.",
            "No personal reaction at the end."
          ],
          "rubric_dimensions": ["task_realization", "coherence_structure", "sociolinguistic_appropriateness", "lexicon", "morphosyntax", "orthography"],
          "task_specific_rubric": {
            "task_realization": {
              "B2_target": "A complete short narrative with chronology, concrete detail, and a personal reaction; addressee named.",
              "common_below_B2": "Bare list of events; no detail; no reaction; off-topic."
            },
            "coherence_structure": {
              "B2_target": "Time markers structure the narrative; transitions between events are smooth.",
              "common_below_B2": "Events juxtaposed with 'et' or 'puis' only; unclear sequence."
            },
            "sociolinguistic_appropriateness": {
              "B2_target": "Friendly informal register with named addressee; closing formula adapted.",
              "common_below_B2": "Mismatched register or impersonal tone."
            },
            "lexicon": {
              "B2_target": "Vocabulary of feelings, of the activity domain (work, health, culture, administration); a couple of evaluative adjectives.",
              "common_below_B2": "Generic verbs ('faire', 'aller') and no descriptive vocabulary."
            },
            "morphosyntax": {
              "B2_target": "Coherent use of passé composé for events and imparfait for context/state; pronouns y/en if relevant.",
              "common_below_B2": "Tense errors that obscure the chronology; missing auxiliaries."
            },
            "orthography": {
              "B2_target": "Past participle agreements correct in most cases; readable punctuation.",
              "common_below_B2": "Repeated past participle errors that obscure meaning."
            }
          }
        },
        {
          "task_number": 6,
          "id": "written_task_3",
          "name_fr": "Texte d'opinion",
          "name_en": "Short opinion text",
          "suggested_duration_minutes": 12,
          "word_count": { "min": 40, "max": 90, "target": 85 },
          "format": "Post a short opinion text on a forum, blog, or community site about a familiar topic.",
          "objective": "State a clear opinion, justify it with two arguments and an example or concession, in a register adapted to a public forum.",
          "expected_structure": [
            "Opening that signals the position",
            "First argument with a reason",
            "Second argument with an example",
            "A concession or nuance",
            "Brief closing"
          ],
          "required_elements": [
            "Explicit position from the very first sentence",
            "Two distinct justifications",
            "One concrete example OR one concession",
            "Connectors of argumentation ('d'abord', 'ensuite', 'cependant', 'par exemple', 'donc')",
            "Stay within 40-90 words"
          ],
          "strategy_tips": [
            "Decide your position before writing the first word.",
            "Plan two arguments that are genuinely different (not two formulations of the same point).",
            "If you nuance, do it in one sentence near the end, not throughout.",
            "Aim for the upper part of the word range (75-90) to demonstrate development."
          ],
          "common_pitfalls": [
            "Hedged opening that hides the position.",
            "Repetition of one argument in two forms.",
            "Concession that turns into a second contradictory opinion.",
            "Writing as if for a private message instead of a public forum."
          ],
          "rubric_dimensions": ["task_realization", "coherence_structure", "sociolinguistic_appropriateness", "lexicon", "morphosyntax", "orthography"],
          "task_specific_rubric": {
            "task_realization": {
              "B2_target": "Clear position, 2 distinct justifications, an example or concession, conclusion; word count respected.",
              "common_below_B2": "Position unclear; one argument only; out of word count."
            },
            "coherence_structure": {
              "B2_target": "Argumentative connectors structure the text; reader can spot the plan at a glance.",
              "common_below_B2": "Stream of statements without visible argumentative architecture."
            },
            "sociolinguistic_appropriateness": {
              "B2_target": "Tone adapted to a public forum: opinionated but courteous, no aggressive or offensive language.",
              "common_below_B2": "Either too personal/emotional, or too academic for a forum context."
            },
            "lexicon": {
              "B2_target": "Topic-relevant vocabulary, evaluative adjectives, modalizers ('selon moi', 'à mon avis', 'il me semble').",
              "common_below_B2": "Empty evaluative vocabulary; repeated 'bon', 'mauvais'."
            },
            "morphosyntax": {
              "B2_target": "Subjunctive after frequent triggers; conditional for opinion; complex sentences with 'bien que', 'parce que', 'si'.",
              "common_below_B2": "Only simple sentences; absent subjunctive."
            },
            "orthography": {
              "B2_target": "Spelling sufficient; agreements respected most of the time.",
              "common_below_B2": "Multiple errors per sentence; missing accents that change meaning."
            }
          }
        }
      ]
    }
  ],
  "questions": [
    {
      "id": "q001",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Présentez-vous brièvement : qui êtes-vous, que faites-vous actuellement et qu'est-ce qui est important pour vous dans la vie de tous les jours ?",
      "themes": ["identité", "vie quotidienne", "valeurs"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Identité courte (nom, âge, ville, parcours)",
          "Activité actuelle (travail, études, formation)",
          "Ce qui compte au quotidien (famille, équilibre, santé, apprentissage)",
          "Conclusion personnelle ouverte"
        ],
        "reference_answer": "Je m'appelle Sarah, j'ai trente-deux ans et je vis à Lyon depuis huit ans. Je suis originaire du Maroc, mais j'ai fait une grande partie de mes études en France, ce qui m'a beaucoup aidée à m'intégrer. Actuellement, je travaille comme assistante de gestion dans une petite entreprise. Mon métier consiste à organiser les rendez-vous, gérer les factures et accompagner les nouveaux salariés pendant leurs premières semaines. C'est un poste assez varié, ce qui me convient bien parce que je n'aime pas la routine. En dehors du travail, ce qui compte vraiment pour moi, c'est l'équilibre entre ma vie professionnelle et ma vie personnelle. Je vis en couple et nous avons une petite fille de quatre ans, donc je fais attention à finir mes journées à une heure raisonnable. Le soir, on prend le temps de cuisiner et de discuter. Le week-end, on essaie toujours de faire au moins une sortie en famille, par exemple au parc ou dans un musée. Ce qui me tient aussi à cœur, c'est d'apprendre quelque chose chaque semaine. En ce moment, je perfectionne mon français à l'écrit, parce que je prépare le TCF, et je suis également un cours de cuisine en ligne. Je trouve que continuer à apprendre, même de petites choses, donne un vrai sens aux journées. Enfin, j'attache beaucoup d'importance à la santé. Je marche au moins trente minutes par jour pour aller au travail et je fais du yoga deux fois par semaine. Voilà, c'est un peu ma vie en quelques mots.",
        "alternative_answer": "Bonjour, je m'appelle Karim, j'ai vingt-huit ans et je suis arrivé en France il y a quatre ans pour rejoindre mon frère. Aujourd'hui, je vis à Toulouse et je travaille comme technicien dans une entreprise de maintenance informatique. Concrètement, je me déplace chez les clients pour réparer leurs ordinateurs ou installer de nouveaux équipements. J'aime ce métier parce qu'il est concret et que je rencontre beaucoup de gens différents. Dans ma vie de tous les jours, ce qui est important pour moi, c'est d'abord la famille. J'appelle mes parents au Maroc presque tous les jours et je leur rends visite deux fois par an. Ensuite, le sport joue un grand rôle. Je cours trois fois par semaine au bord de la Garonne et, le samedi, je joue au football avec un groupe d'amis. Cela m'aide à me détendre après une semaine chargée. J'accorde aussi beaucoup d'attention à mon avenir professionnel. Je suis en train de préparer un diplôme en cybersécurité, parce que je voudrais évoluer vers un poste plus spécialisé d'ici deux ans. C'est exigeant, mais ça me motive. Enfin, j'aime garder du temps pour la lecture le soir, surtout en français. Cela m'aide à enrichir mon vocabulaire et à mieux comprendre la culture du pays où je vis maintenant. Voilà, en quelques minutes, qui je suis et ce qui compte pour moi.",
        "key_elements_to_cover": [
          "Présentation personnelle (nom, situation actuelle)",
          "Activité principale (travail/études)",
          "Au moins deux choses importantes au quotidien avec justification",
          "Une projection vers l'avenir ou un objectif"
        ],
        "key_vocabulary": ["originaire de", "actuellement", "consister à", "équilibre", "tenir à cœur", "accorder de l'importance à", "se détendre", "évoluer"],
        "key_grammar": ["Présent", "Passé composé pour le parcours", "Pronoms relatifs (qui, que, ce qui)", "Cause (parce que, car)", "But (pour + infinitif)"]
      },
      "evaluation_focus": [
        "L'authenticité personnelle (pas de récitation)",
        "La capacité à enchaîner des idées avec des connecteurs",
        "Au moins deux temps verbaux maîtrisés",
        "La réaction aux relances éventuelles"
      ]
    },
    {
      "id": "q002",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Parlez-moi de votre parcours d'études ou de formation et expliquez en quoi il a influencé votre situation actuelle.",
      "themes": ["études", "formation", "parcours professionnel"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Présentation du parcours d'études (ordre chronologique)",
          "Choix marquants et raisons",
          "Lien explicite avec la situation actuelle",
          "Réflexion personnelle sur ce que ce parcours a apporté"
        ],
        "reference_answer": "Mon parcours scolaire s'est principalement déroulé dans mon pays d'origine, en Algérie, où j'ai fait toute ma scolarité jusqu'au baccalauréat scientifique. Ensuite, j'ai commencé des études d'ingénieur en informatique à l'université d'Alger, que j'ai terminées il y a cinq ans. Pendant ces études, j'ai suivi plusieurs stages dans des entreprises locales, ce qui m'a permis de découvrir la programmation web et le travail en équipe. C'est à ce moment-là que j'ai décidé de me spécialiser dans le développement de sites internet. Après mon diplôme, j'ai travaillé deux ans dans une société d'informatique à Alger, puis je suis venu en France pour faire un master de spécialisation à Lille. Cette deuxième formation a été très importante, parce qu'elle m'a obligé à rédiger en français de manière régulière et à présenter mes projets à l'oral. Aujourd'hui, ce parcours m'a clairement aidé à trouver mon poste actuel, qui est développeur dans une entreprise de services numériques. Sans le master, je pense que je n'aurais pas pu accéder à ce type de poste, parce que la concurrence est forte dans ce secteur. Sur le plan personnel, mes études m'ont appris à être organisé, à respecter les délais et à demander de l'aide quand je ne comprends pas un sujet. C'est précieux dans mon travail de tous les jours. Enfin, c'est aussi grâce à mes études en France que j'ai rencontré ma femme et que j'ai construit ma vie ici. Donc on peut dire que ce parcours a influencé non seulement ma carrière, mais aussi ma vie personnelle.",
        "alternative_answer": "Mon parcours est un peu particulier, parce que je n'ai pas suivi une trajectoire très classique. Après le lycée dans mon pays, je n'étais pas sûr de ce que je voulais faire. J'ai donc commencé par travailler dans le commerce pendant deux ans pour gagner de l'expérience. Cette période a été très formatrice, mais j'ai vite compris que je voulais reprendre mes études. Je me suis alors inscrit à une formation d'aide-soignant, qui durait dix-huit mois. C'était un choix fort, parce que je voulais un métier utile, en contact avec les gens. Après l'obtention de mon diplôme, j'ai travaillé dans une maison de retraite, puis à l'hôpital pendant quatre ans. Quand je suis arrivé en France, j'ai dû refaire valider mon diplôme et passer des examens complémentaires. Cela a été long, mais aujourd'hui je travaille comme aide-soignant dans une clinique privée, à côté de chez moi. Mon parcours m'a beaucoup influencé : je sais que j'ai besoin d'un travail concret, où je vois rapidement les résultats de mes efforts. J'ai aussi appris la patience, surtout avec les personnes âgées et leurs familles. Enfin, ces premières années dans le commerce, même si elles n'ont pas l'air liées, m'aident encore à communiquer avec différentes personnalités. Donc, même les détours d'un parcours peuvent servir, finalement.",
        "key_elements_to_cover": [
          "Étapes principales du parcours en ordre",
          "Choix ou tournants expliqués",
          "Lien clair avec la situation actuelle",
          "Apport personnel (compétences, valeurs)"
        ],
        "key_vocabulary": ["se dérouler", "obtenir un diplôme", "se spécialiser dans", "se reconvertir", "valider un diplôme", "stage", "concurrence", "trajectoire"],
        "key_grammar": ["Passé composé pour les étapes", "Imparfait pour le contexte", "Cause/conséquence (parce que, donc, c'est pourquoi)", "Conditionnel passé (j'aurais pu)"]
      },
      "evaluation_focus": [
        "Chronologie claire",
        "Lien explicite passé → présent",
        "Vocabulaire des études et du travail",
        "Réflexion personnelle, pas seulement une liste"
      ]
    },
    {
      "id": "q003",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Décrivez votre travail actuel, ou votre dernière activité professionnelle, et dites ce que vous aimez et ce que vous trouvez difficile.",
      "themes": ["travail", "activité professionnelle", "satisfaction"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Description du poste (entreprise, missions, contexte)",
          "Ce que j'aime, avec justification et exemple",
          "Ce que je trouve difficile, avec justification",
          "Bilan personnel ou perspective"
        ],
        "reference_answer": "Actuellement, je travaille comme responsable de rayon dans un supermarché à Bordeaux. Je suis dans cette entreprise depuis trois ans, et je m'occupe principalement du rayon fruits et légumes. Mes missions sont assez variées : je passe les commandes auprès des fournisseurs, je vérifie la qualité des produits à la livraison, je gère une équipe de quatre personnes et je m'assure que le rayon reste attractif tout au long de la journée. Ce que j'aime vraiment dans ce métier, c'est le contact avec mon équipe. Nous avons construit une bonne ambiance, on se soutient quand il y a beaucoup de travail, et je trouve cela précieux. J'aime aussi voir le résultat concret de mon travail : quand un rayon est bien organisé, joliment présenté, et que les clients viennent me complimenter, c'est très valorisant. Enfin, j'apprécie le fait de bouger toute la journée, parce que je ne supporterais pas un travail uniquement assis devant un ordinateur. En revanche, ce que je trouve difficile, ce sont les horaires. Je commence souvent à six heures du matin et je travaille un samedi sur deux. Sur la durée, c'est fatigant, surtout pour la vie de famille. Une autre difficulté, c'est la pression pendant les périodes de fêtes, comme Noël ou Pâques, où il faut tout préparer en très peu de temps. Malgré cela, je reste motivé, parce que j'ai des perspectives d'évolution et que mon directeur me fait confiance. À moyen terme, j'aimerais devenir adjoint de magasin, ce qui me permettrait de prendre encore plus de responsabilités.",
        "alternative_answer": "Mon dernier travail était infirmière dans un service de pédiatrie à Marseille. J'y suis restée pendant six ans, jusqu'à mon déménagement récent. Mes journées étaient très chargées : surveillance des enfants hospitalisés, soins quotidiens, communication avec les familles, et coordination avec les médecins. Ce que j'aimais le plus, c'était la relation avec les enfants. Même quand ils étaient malades, ils gardaient souvent une énergie incroyable, ce qui rendait l'ambiance plus légère. J'aimais aussi l'aspect technique du métier : il faut être précise, calme, et capable de réagir vite si la situation change. Enfin, je trouvais que travailler en équipe avec des collègues très soudés donnait beaucoup de sens à mes journées. Cependant, ce métier était aussi très difficile sur le plan émotionnel. Certaines situations étaient lourdes à porter, surtout quand on s'attache à un enfant qui ne va pas bien. La fatigue physique était également importante, parce que les horaires de nuit s'enchaînaient parfois sur plusieurs semaines. Aujourd'hui, je suis en pause et je cherche à reprendre dans une structure plus petite, peut-être un cabinet médical, pour conserver ma vocation tout en retrouvant un rythme plus équilibré.",
        "key_elements_to_cover": [
          "Nom du poste et missions concrètes",
          "Au moins 2 aspects positifs justifiés",
          "Au moins 1 difficulté justifiée",
          "Une conclusion (perspective, bilan)"
        ],
        "key_vocabulary": ["s'occuper de", "missions", "responsabilités", "valorisant", "exigeant", "perspectives d'évolution", "horaires", "équipe"],
        "key_grammar": ["Présent descriptif", "Imparfait si activité passée", "Comparaison (plus que, moins que)", "Opposition (en revanche, cependant, malgré)"]
      },
      "evaluation_focus": [
        "Description concrète du poste",
        "Équilibre positif/négatif",
        "Justifications réelles, pas génériques",
        "Vocabulaire professionnel"
      ]
    },
    {
      "id": "q004",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Comment avez-vous appris le français jusqu'à présent ? Quelles méthodes vous ont le plus aidé ?",
      "themes": ["apprentissage", "français", "méthodes"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Premier contact avec le français (où, quand, pourquoi)",
          "Étapes principales de l'apprentissage",
          "Méthodes les plus efficaces avec justification",
          "Méthodes qui ont moins fonctionné, ou difficultés persistantes",
          "Objectif actuel"
        ],
        "reference_answer": "J'ai commencé à apprendre le français à l'école, dans mon pays, quand j'avais environ dix ans. À cette époque, c'était surtout de la grammaire et du vocabulaire à apprendre par cœur, donc honnêtement, je n'avais pas une grande passion pour cette langue. Le vrai déclic est venu plus tard, quand j'ai obtenu une bourse pour faire un séjour de trois mois à Montpellier, après le lycée. Là, j'ai été obligé de parler français tous les jours, avec ma famille d'accueil et mes camarades de classe. C'est là que j'ai compris que je pouvais vraiment communiquer, même si je faisais beaucoup d'erreurs. Depuis mon installation en France, il y a cinq ans, j'ai utilisé plusieurs méthodes. Ce qui m'a le plus aidé, c'est sans doute la conversation au quotidien : au travail, chez le médecin, à la boulangerie. C'est en parlant avec des francophones que j'ai vraiment progressé, surtout pour la fluidité et la prononciation. Une autre méthode très efficace pour moi a été de regarder des séries françaises avec des sous-titres en français. Cela m'a permis d'enrichir mon vocabulaire et de mieux comprendre les expressions familières. En revanche, les applications mobiles m'ont moins aidé, parce que je trouvais les exercices répétitifs et trop courts pour vraiment progresser. Je préfère prendre un livre ou un article et faire l'effort de comprendre. En ce moment, je prends aussi des cours du soir avec une professeure, surtout pour préparer le TCF et travailler l'écrit, qui reste mon point faible. Mon objectif principal, c'est d'atteindre un B2 solide d'ici l'examen.",
        "alternative_answer": "Mon apprentissage du français a été très progressif, parce que je n'ai jamais étudié cette langue à l'école. J'ai vraiment commencé en arrivant en France, il y a sept ans, à l'âge adulte. Au début, c'était difficile, parce que je devais à la fois trouver un travail, m'adapter à un nouveau pays et apprendre une langue complètement nouvelle. Heureusement, j'ai trouvé une association de quartier qui proposait des cours gratuits le samedi matin. Pendant deux ans, j'y suis allée régulièrement, et c'est probablement la méthode qui m'a le plus aidée. Les enseignants étaient bénévoles, mais très patients, et nous étions un petit groupe, donc je pouvais poser toutes mes questions. À côté, j'ai écouté beaucoup de radio en français, surtout en cuisinant ou en faisant le ménage. Cela m'a habituée au rythme de la langue et aux différents accents. Plus récemment, j'ai aussi commencé à lire des romans simples, par exemple des polars, qui m'ont aidée à enrichir mon vocabulaire sans me décourager. Ce qui a été moins efficace pour moi, c'est apprendre des listes de mots tout seule. Sans contexte, j'oubliais tout en quelques jours. Aujourd'hui, je continue à apprendre, surtout au travail, et je vise le B2 pour la naturalisation.",
        "key_elements_to_cover": [
          "Quand et comment l'apprentissage a commencé",
          "Au moins deux méthodes utilisées avec opinion",
          "Différenciation entre ce qui marche et ce qui marche moins",
          "Objectif actuel"
        ],
        "key_vocabulary": ["apprentissage", "déclic", "communiquer", "progresser", "fluidité", "enrichir le vocabulaire", "expressions familières", "atteindre un niveau"],
        "key_grammar": ["Passé composé / imparfait", "Comparatifs", "Pronoms relatifs", "Marqueurs temporels (au début, ensuite, depuis, en ce moment)"]
      },
      "evaluation_focus": [
        "Récit d'apprentissage cohérent",
        "Évaluation critique des méthodes",
        "Vocabulaire de l'apprentissage",
        "Maîtrise du passé"
      ]
    },
    {
      "id": "q005",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Décrivez votre lieu de vie ou votre quartier : qu'est-ce qui vous plaît, et qu'aimeriez-vous y changer ?",
      "themes": ["logement", "quartier", "vie locale"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Localisation et présentation rapide",
          "Atouts du quartier (au moins deux, avec exemples)",
          "Aspects à améliorer (au moins un, justifié)",
          "Bilan personnel ou comparaison avec un ailleurs"
        ],
        "reference_answer": "J'habite actuellement dans un quartier qui s'appelle Villejean, à Rennes, depuis environ trois ans. C'est un quartier situé à l'ouest de la ville, plutôt calme et résidentiel, avec beaucoup d'étudiants parce que la grande université se trouve juste à côté. Ce qui me plaît le plus dans mon quartier, c'est d'abord l'accès aux transports. Il y a une station de métro à cinq minutes à pied, ce qui me permet d'être dans le centre-ville en moins d'un quart d'heure. C'est très pratique pour mon travail et pour mes loisirs. Ensuite, j'apprécie beaucoup la diversité du quartier. On rencontre des familles, des étudiants, des personnes âgées et des gens venus de différents pays, ce qui crée une ambiance assez vivante. Il y a aussi un grand parc à proximité, où je vais courir le week-end, et un marché chaque mardi matin où j'achète mes fruits et légumes. Cela donne un côté un peu villageois que j'aime beaucoup. Cependant, il y a quelques choses que j'aimerais voir changer. Par exemple, le soir, certaines rues sont très peu éclairées, et les femmes ne se sentent pas toujours en sécurité. J'aimerais aussi qu'il y ait plus de petits commerces de proximité, parce qu'à part la boulangerie et le tabac, il faut prendre le métro pour faire la moindre course. Enfin, on manque clairement de lieux culturels comme un cinéma ou un café-théâtre. Malgré ces défauts, je me sens bien dans ce quartier et je n'ai pas envie de déménager. C'est devenu un peu mon chez-moi.",
        "alternative_answer": "Je vis dans un petit village à environ vingt kilomètres de Nantes. C'est un endroit assez tranquille, avec moins de mille habitants, entouré de champs et de forêts. Ce qui me plaît, c'est avant tout la qualité de vie. Il n'y a presque pas de bruit, l'air est meilleur qu'en ville, et on peut facilement se promener à pied ou à vélo. J'aime aussi le fait que tout le monde se connaît un peu, ce qui donne un vrai sentiment de communauté. Quand je suis arrivée, plusieurs voisins sont venus se présenter et m'apporter quelque chose à manger, ce qui m'a beaucoup touchée. En revanche, vivre à la campagne a aussi des inconvénients. Ce que j'aimerais changer, c'est surtout l'offre de transports en commun. Il y a seulement deux bus par jour pour aller à Nantes, donc sans voiture, on est vraiment isolé. Je trouve dommage qu'il n'y ait pas non plus d'activités culturelles régulières pour les adultes, comme des cours du soir ou des conférences. Pour le reste, je suis très contente de vivre ici, surtout depuis la naissance de mon fils.",
        "key_elements_to_cover": [
          "Localisation et type de quartier",
          "Au moins 2 aspects positifs avec exemples",
          "Au moins 1 aspect à améliorer avec justification",
          "Sentiment personnel global"
        ],
        "key_vocabulary": ["résidentiel", "à proximité", "transports en commun", "ambiance", "commerces de proximité", "qualité de vie", "isolé", "se sentir en sécurité"],
        "key_grammar": ["Présent descriptif", "Subjonctif après 'aimer que' / 'il faudrait que'", "Comparatifs", "Pronoms relatifs (où, dont)"]
      },
      "evaluation_focus": [
        "Description précise et concrète",
        "Équilibre points forts / points faibles",
        "Vocabulaire de la ville et du logement",
        "Capacité à exprimer un souhait (subjonctif, conditionnel)"
      ]
    },
    {
      "id": "q006",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Parlez de vos habitudes quotidiennes en semaine. Y a-t-il une habitude que vous aimeriez améliorer ?",
      "themes": ["habitudes", "vie quotidienne", "amélioration personnelle"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Routine matinale",
          "Journée de travail / activités principales",
          "Soirée et rituels",
          "Habitude à améliorer + raison",
          "Engagement ou plan concret"
        ],
        "reference_answer": "En semaine, mes journées sont assez rythmées et plutôt régulières. Je me lève vers six heures et demie. La première chose que je fais, c'est préparer un café et lire les actualités sur mon téléphone pendant une vingtaine de minutes. Ensuite, je prends ma douche, je m'habille et je prépare un petit-déjeuner rapide, en général des fruits et un yaourt. Je quitte la maison vers sept heures et demie pour aller au travail à vélo, ce qui me prend environ vingt-cinq minutes. Au bureau, je commence par traiter mes mails urgents, puis je m'occupe de mes dossiers principaux jusqu'à midi. Je déjeune souvent avec mes collègues, soit à la cantine, soit dans un petit restaurant à côté. L'après-midi est généralement consacré aux réunions et aux projets en équipe. Je termine ma journée vers dix-sept heures trente. Le soir, j'aime cuisiner tranquillement, dîner avec mon mari et regarder une série pendant une heure. Je me couche assez tôt, vers vingt-deux heures trente, parce que j'ai besoin de bien dormir. L'habitude que j'aimerais vraiment améliorer, c'est mon rapport au téléphone le soir. J'ai tendance à le consulter juste avant de dormir, ce qui n'est pas très bon pour mon sommeil. Je me suis rendu compte que je dormais moins bien quand je passais une heure sur les réseaux sociaux. J'ai donc décidé de poser mon téléphone dans le salon une heure avant de me coucher, et de lire un livre à la place. Pour l'instant, j'y arrive trois ou quatre soirs par semaine, ce qui est déjà un progrès.",
        "alternative_answer": "Mes journées de semaine sont très chargées parce que je jongle entre mon travail, mes études du soir et ma famille. Je me lève à cinq heures et demie, ce qui est tôt, mais c'est le seul moment calme que j'ai pour moi. J'en profite pour faire vingt minutes de stretching et écouter un podcast en français. Ensuite, je prépare le petit-déjeuner pour mes deux enfants, je les emmène à l'école, puis je file au travail. Je suis vendeuse dans une boutique de vêtements, donc je suis debout toute la journée, ce qui est physique. Le soir, après avoir récupéré les enfants et préparé le dîner, j'ai un cours de comptabilité en ligne deux fois par semaine. C'est intense, mais c'est important pour ma reconversion. L'habitude que je voudrais améliorer, c'est mon alimentation. Comme je manque de temps, je mange souvent des plats préparés ou des sandwichs, ce qui n'est pas idéal pour la santé. Je voudrais cuisiner davantage le dimanche pour préparer mes repas de la semaine. C'est un projet, je n'ai pas encore réussi à le mettre en place régulièrement.",
        "key_elements_to_cover": [
          "Description chronologique d'une journée type",
          "Au moins 3 moments différents (matin, journée, soir)",
          "Une habitude à améliorer identifiée",
          "Raison de l'amélioration et plan d'action"
        ],
        "key_vocabulary": ["rythmée", "régulière", "consacrer", "se rendre compte", "avoir tendance à", "améliorer", "progrès", "rituel"],
        "key_grammar": ["Présent d'habitude", "Pronoms réfléchis (se lever, se coucher)", "Conditionnel (j'aimerais)", "Connecteurs temporels"]
      },
      "evaluation_focus": [
        "Chronologie claire de la journée",
        "Vocabulaire de la routine",
        "Réflexion personnelle sur soi",
        "Capacité à exprimer un souhait et un plan"
      ]
    },
    {
      "id": "q007",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Quels sont vos loisirs principaux ? Expliquez pourquoi ils vous conviennent aujourd'hui plus qu'avant.",
      "themes": ["loisirs", "centres d'intérêt", "évolution personnelle"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Présentation des loisirs actuels",
          "Détails concrets sur la pratique (fréquence, contexte)",
          "Comparaison avec les loisirs d'avant",
          "Raison pour laquelle ils conviennent mieux maintenant",
          "Conclusion personnelle"
        ],
        "reference_answer": "Aujourd'hui, j'ai trois loisirs principaux qui occupent vraiment mon temps libre. Le premier, c'est la randonnée. Presque tous les week-ends, avec mon mari et un groupe d'amis, on part marcher dans la région, dans les Vosges ou dans le Jura. Le deuxième, c'est la lecture. Je lis surtout des romans contemporains, en français maintenant, et je fais partie d'un petit club de lecture qui se réunit une fois par mois. Enfin, je fais du jardinage, parce que nous avons un petit jardin depuis deux ans. Quand j'étais plus jeune, mes loisirs étaient très différents. J'aimais sortir en boîte de nuit, aller à de grands concerts, faire la fête jusqu'à très tard. C'était amusant, mais souvent fatigant et un peu superficiel. Aujourd'hui, mes loisirs me conviennent bien plus, parce qu'ils correspondent à ce dont j'ai vraiment besoin. La randonnée, par exemple, me permet de me déconnecter du travail, de prendre l'air et de discuter calmement avec des proches. Cela me fait beaucoup plus de bien qu'une soirée tardive. La lecture m'apporte aussi quelque chose de précieux. Je découvre des auteurs, je voyage en imagination, et je rencontre d'autres lecteurs lors du club. C'est un loisir qui nourrit l'esprit, ce que je ne recherchais pas autant à vingt ans. Quant au jardinage, c'est une vraie surprise pour moi, parce que je n'aurais jamais pensé l'aimer. Voir les plantes pousser, prendre soin du potager, c'est apaisant et concret. Je pense qu'avec l'âge, j'apprécie davantage les plaisirs simples et durables que les sensations fortes.",
        "alternative_answer": "Mes deux loisirs principaux aujourd'hui sont le sport et le cinéma. Je joue au football le mardi soir, dans une équipe amateur, et je vais à la salle de sport deux fois par semaine. Le week-end, j'aime beaucoup aller au cinéma, surtout pour découvrir des films français ou européens, parce que cela m'aide aussi à progresser en français. Avant, quand j'étais plus jeune, mon principal loisir, c'était les jeux vidéo. Je passais parfois plusieurs heures par jour devant l'écran, le soir et le week-end. À l'époque, ça me convenait, parce que c'était une façon de me détendre et de retrouver mes amis en ligne. Mais avec le temps, j'ai senti que ça me fatiguait au lieu de me reposer. Mes loisirs actuels me conviennent mieux pour plusieurs raisons. D'abord, ils sont plus actifs, donc ils sont meilleurs pour ma santé physique et mentale. Ensuite, le foot me permet de sortir de chez moi et de rencontrer des gens, ce qui n'était pas le cas avec les jeux vidéo. Enfin, le cinéma m'apporte une vraie ouverture culturelle. Aujourd'hui, j'ai donc l'impression d'avoir trouvé un meilleur équilibre.",
        "key_elements_to_cover": [
          "Au moins deux loisirs concrets actuels",
          "Description d'au moins un loisir d'avant",
          "Comparaison explicite avant/maintenant",
          "Justifications personnelles"
        ],
        "key_vocabulary": ["temps libre", "se déconnecter", "passion", "ouverture culturelle", "convenir à", "nourrir l'esprit", "se détendre", "équilibre"],
        "key_grammar": ["Présent / imparfait", "Comparatifs (plus que, moins que, mieux)", "Pronoms relatifs", "Cause (parce que, car)"]
      },
      "evaluation_focus": [
        "Loisirs concrets, pas génériques",
        "Comparaison passé/présent claire",
        "Réflexion personnelle",
        "Maîtrise du présent et de l'imparfait"
      ]
    },
    {
      "id": "q008",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Racontez un événement récent qui vous a marqué et expliquez pourquoi il a été important pour vous.",
      "themes": ["événement marquant", "expérience personnelle", "émotion"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Identification de l'événement (quoi, quand, où)",
          "Récit chronologique du déroulement",
          "Détails marquants ou émotions ressenties",
          "Raison pour laquelle l'événement a été important",
          "Impact actuel ou leçon retenue"
        ],
        "reference_answer": "L'événement qui m'a vraiment marqué récemment, c'est l'obtention de mon permis de conduire, il y a deux mois. Cela peut sembler banal, mais pour moi, c'était un vrai défi personnel, parce que j'ai trente-cinq ans et que je n'avais jamais pris le temps de le passer plus tôt. Tout a commencé l'année dernière, quand j'ai changé de travail. Mon nouveau bureau est à dix kilomètres de chez moi, et il n'y a pas de transports directs. J'ai donc compris que je devais absolument apprendre à conduire pour ne plus dépendre des autres. Je me suis inscrite dans une auto-école près de chez moi, et j'ai pris des cours pendant huit mois. Honnêtement, ce n'a pas été facile. J'ai raté l'examen pratique deux fois avant de le réussir. Lors du deuxième échec, j'ai même pensé à abandonner, parce que je perdais confiance en moi. Heureusement, mon mari et mon moniteur m'ont beaucoup encouragée, et j'ai persévéré. Le jour où l'examinateur m'a annoncé que j'avais réussi, j'ai presque pleuré de joie. Cet événement a été important pour moi pour plusieurs raisons. D'abord, parce qu'il m'a redonné confiance en mes capacités. Ensuite, parce qu'il m'a apporté une vraie liberté au quotidien : je peux aller travailler, faire mes courses, partir en week-end sans dépendre de personne. Enfin, c'était une leçon de persévérance. J'ai compris qu'il ne faut jamais renoncer après un échec, même si on est plus âgé que les autres dans la même situation. C'est une expérience qui me servira sans doute dans d'autres défis à venir.",
        "alternative_answer": "L'événement le plus marquant pour moi récemment, c'est la naissance de ma nièce, il y a trois mois. C'est un événement heureux, mais qui a aussi changé beaucoup de choses dans notre famille. Tout s'est passé un samedi matin. Ma sœur m'a appelée à six heures pour me dire qu'elle partait à la maternité. Toute la journée, j'ai attendu avec mes parents, à la fois excitée et un peu inquiète. La petite est née en début de soirée, en bonne santé, et nous avons pu lui rendre visite le lendemain. Pourquoi cet événement a-t-il été si important ? D'abord, parce que c'est le premier bébé de la famille de notre génération. Cela a beaucoup ému mes parents, qui sont maintenant grands-parents pour la première fois. Ensuite, parce que cela a transformé ma relation avec ma sœur. On se voit plus souvent, on partage de nouvelles discussions sur la parentalité, et je me sens plus proche d'elle qu'avant. Enfin, sur un plan personnel, cela m'a fait réfléchir à mon propre projet d'enfant. Je n'avais jamais ressenti ce désir aussi fort qu'aujourd'hui. C'est un événement qui marque vraiment une nouvelle étape pour toute la famille.",
        "key_elements_to_cover": [
          "Identification claire de l'événement et du contexte",
          "Récit chronologique avec marqueurs temporels",
          "Émotions ressenties exprimées",
          "Au moins deux raisons d'importance",
          "Lien avec le présent ou leçon"
        ],
        "key_vocabulary": ["marquer", "défi personnel", "persévérer", "redonner confiance", "ému(e)", "liberté", "leçon", "étape"],
        "key_grammar": ["Passé composé / imparfait", "Plus-que-parfait (j'avais pensé)", "Connecteurs temporels", "Conditionnel passé (j'aurais pu)"]
      },
      "evaluation_focus": [
        "Récit clair et structuré",
        "Émotions exprimées",
        "Justification de l'importance",
        "Maîtrise des temps du passé"
      ]
    },
    {
      "id": "q009",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Parlez d'un voyage ou d'un déplacement dont vous gardez un bon souvenir. Qu'est-ce que cette expérience vous a appris ?",
      "themes": ["voyage", "souvenir", "apprentissage"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Présentation du voyage (où, quand, avec qui, pourquoi)",
          "Un ou deux moments marquants",
          "Émotions et impressions",
          "Ce que ce voyage a appris (au moins deux apprentissages)",
          "Conclusion personnelle ou impact actuel"
        ],
        "reference_answer": "Le voyage dont je garde le meilleur souvenir, c'est un voyage en Italie, plus précisément en Sicile, que j'ai fait avec deux amies il y a trois ans. Nous étions parties pour dix jours, sans plan vraiment précis, juste un vol et une voiture de location. Cela peut paraître risqué, mais finalement, c'est ce qui a rendu le voyage si spécial. Pendant ces dix jours, nous avons traversé presque toute l'île. Nous avons commencé à Palerme, puis nous avons longé la côte sud jusqu'à Syracuse, en nous arrêtant dans des petits villages. Un moment qui m'a particulièrement marquée, c'est une soirée à Cefalù. Nous avons mangé du poisson dans un petit restaurant familial, en bord de mer, pendant que le soleil se couchait. Le propriétaire est venu discuter avec nous en mélangeant français, italien et anglais, et il nous a offert un dessert. Ce moment simple résume tout ce que j'aime dans les voyages : la rencontre, la simplicité, la beauté du quotidien. Cette expérience m'a appris plusieurs choses importantes. D'abord, qu'il n'est pas nécessaire de tout planifier pour qu'un voyage soit réussi. L'imprévu apporte souvent les plus beaux souvenirs. Ensuite, j'ai compris à quel point les rencontres comptaient plus que les monuments. Aujourd'hui, je me souviens davantage des personnes que des lieux célèbres. Enfin, ce voyage m'a appris à mieux gérer mon stress, parce qu'il y a toujours des imprévus, comme une voiture qui tombe en panne ou un hôtel complet, et qu'il faut savoir s'adapter. Depuis, j'aborde les voyages, et même la vie quotidienne, avec plus de souplesse.",
        "alternative_answer": "Le déplacement qui m'a vraiment marqué, c'est un voyage que j'ai fait au Japon en 2019, pour rendre visite à un ami d'enfance qui vivait à Tokyo. Je suis resté deux semaines et c'était la première fois que je voyageais aussi loin, seul. Tout était nouveau pour moi : la langue, l'écriture, la nourriture, et même la manière dont les gens se comportent dans la rue. Mon ami m'a fait découvrir la ville à pied, mais aussi des coins moins touristiques, comme un quartier où l'on mange dans de minuscules restaurants pour quelques euros. Le moment le plus fort a été notre voyage à Kyoto en train à grande vitesse. Visiter les temples sous la pluie, tôt le matin, m'a donné une émotion que je n'avais jamais ressentie avant. Cette expérience m'a beaucoup appris. D'abord, à être autonome, parce que je devais souvent me débrouiller seul, sans parler la langue. Ensuite, à respecter une culture très différente de la mienne, où la politesse et le silence ont énormément d'importance. Enfin, ce voyage m'a donné envie de continuer à découvrir le monde, et c'est pour cette raison que j'économise depuis pour repartir bientôt.",
        "key_elements_to_cover": [
          "Voyage identifié (lieu, date, contexte)",
          "Au moins un moment précis raconté",
          "Émotions et impressions",
          "Au moins deux apprentissages explicites",
          "Lien avec le présent"
        ],
        "key_vocabulary": ["souvenir", "imprévu", "rencontre", "découvrir", "marquer", "se débrouiller", "autonome", "ouverture d'esprit"],
        "key_grammar": ["Passé composé / imparfait", "Plus-que-parfait", "Connecteurs (d'abord, ensuite, enfin)", "Pronom relatif 'dont'"]
      },
      "evaluation_focus": [
        "Récit narratif structuré",
        "Détails sensoriels et émotionnels",
        "Apprentissages explicites",
        "Vocabulaire du voyage"
      ]
    },
    {
      "id": "q010",
      "section": "expression_orale",
      "task_number": 1,
      "task_id": "oral_task_1",
      "task_type_fr": "Présentation / questions personnelles",
      "question": "Quels sont vos projets pour les prochains mois ? Expliquez ce que vous espérez réaliser et comment vous allez vous organiser.",
      "themes": ["projets", "futur", "organisation"],
      "timing": { "duration_minutes": 3, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 220, "ideal": 280, "max": 360 },
        "structure": [
          "Présentation générale des projets (deux ou trois)",
          "Projet principal détaillé",
          "Plan concret pour le réaliser (étapes, délais)",
          "Autres projets brièvement présentés",
          "Conclusion sur la motivation"
        ],
        "reference_answer": "Pour les prochains mois, j'ai plusieurs projets, à la fois professionnels et personnels. Le projet le plus important pour moi, c'est de réussir le TCF IRN, parce que j'en ai besoin pour ma demande de naturalisation. Je me suis fixé l'examen pour le mois de septembre, donc j'ai à peu près quatre mois devant moi. Pour m'organiser, j'ai mis en place une routine assez précise. Trois soirs par semaine, après le travail, je consacre environ une heure à l'écrit : je m'entraîne sur des sujets de production écrite et je révise la grammaire. Le samedi matin, je fais une simulation orale avec une professeure que j'ai trouvée en ligne, pour travailler la spontanéité. Et le dimanche, je lis un article de presse en français et je résume les idées à voix haute. À côté de ce projet principal, je veux aussi reprendre le sport plus sérieusement. J'ai pris un peu de poids depuis le télétravail, et je me sens moins en forme. Je me suis donc inscrite dans une salle de sport à côté du bureau, et je vais essayer d'y aller deux fois par semaine pendant ma pause déjeuner. Enfin, sur le plan familial, nous prévoyons un voyage à Marseille en juillet, pour rendre visite à mes beaux-parents que je n'ai pas vus depuis plus d'un an. Ce sera l'occasion aussi de présenter ma fille à toute la famille élargie. Pour réussir tout cela, je dois rester organisée et ne pas culpabiliser quand un soir, je suis trop fatiguée pour étudier. Je pense que c'est l'équilibre qui me permettra d'aller au bout.",
        "alternative_answer": "Mes projets principaux pour les prochains mois sont surtout professionnels. D'abord, je voudrais finir une formation en comptabilité que j'ai commencée en janvier. Il me reste trois modules et un examen final à passer, normalement en juin. Pour m'organiser, j'ai bloqué deux soirs par semaine et le dimanche matin pour étudier. Ensuite, je cherche activement un nouveau travail. Je suis actuellement vendeur, mais je voudrais évoluer vers un poste d'assistant comptable. J'envoie deux ou trois candidatures par semaine, et j'ai déjà eu deux entretiens, ce qui est encourageant. Pour rester motivé, je me fixe des objectifs hebdomadaires concrets. Sur le plan personnel, j'ai aussi un projet plus léger : apprendre à cuisiner sérieusement. Je suis un cours en ligne tous les quinze jours et j'essaie de cuisiner un nouveau plat chaque dimanche. Enfin, j'aimerais commencer une activité sportive, peut-être la natation, parce que je travaille beaucoup assis et que mon dos commence à me faire mal. Je dois encore trouver une piscine près de chez moi avec des horaires compatibles. Voilà, mes prochains mois seront chargés, mais j'ai bien conscience qu'il faut s'organiser pour avancer.",
        "key_elements_to_cover": [
          "Au moins deux projets distincts",
          "Détails concrets sur le projet principal",
          "Plan d'action avec étapes ou fréquence",
          "Échéances ou délais",
          "Motivation personnelle"
        ],
        "key_vocabulary": ["se fixer un objectif", "consacrer du temps à", "se mettre à", "candidatures", "réaliser un projet", "s'organiser", "prévoir", "échéance"],
        "key_grammar": ["Futur proche (aller + infinitif)", "Futur simple", "Conditionnel (j'aimerais, je voudrais)", "Connecteurs (d'abord, ensuite, enfin)"]
      },
      "evaluation_focus": [
        "Projets concrets, pas généraux",
        "Plan d'action réaliste",
        "Maîtrise des temps du futur",
        "Lien entre projets et motivations"
      ]
    },
    {
      "id": "q011",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis un agent immobilier. Vous cherchez un logement pour les prochains mois. Vous m'expliquez ce que vous cherchez et vous me posez des questions précises.",
      "examiner_role_fr": "Agent immobilier",
      "themes": ["logement", "location", "vie quotidienne"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et présentation de la demande",
          "Description des besoins (type, taille, quartier, budget)",
          "Questions précises (charges, transports, état, bail)",
          "Réaction aux propositions de l'agent et comparaison",
          "Conclusion (visite, suite, remerciements)"
        ],
        "reference_answer": "Bonjour Monsieur, je m'appelle Léa Martin et je cherche un logement à louer pour les six prochains mois, peut-être plus si je trouve quelque chose qui me plaît vraiment. Je travaille depuis peu dans le centre-ville et je voudrais idéalement un appartement situé à moins de vingt minutes de mon bureau, en transports en commun. Concrètement, je cherche un T2, donc un appartement avec une chambre séparée, parce que je télétravaille deux jours par semaine et j'ai besoin d'un coin bureau au calme. Mon budget maximum est de neuf cents euros par mois, charges comprises. J'aurais quelques questions précises. Tout d'abord, est-ce que les charges incluent l'eau et le chauffage, ou seulement l'entretien des parties communes ? Ensuite, pour les logements que vous avez en portefeuille, quels sont les quartiers que vous me recommanderiez en priorité, sachant que je préfère un secteur calme mais bien desservi ? J'ai aussi une question sur le bail : est-il possible de signer un bail mobilité pour neuf mois, ou seulement un bail classique de trois ans ? Enfin, concernant le dossier, quels documents devez-vous absolument avoir pour valider ma candidature ? Je suis en CDI, mais je viens de commencer, donc je n'ai pas encore trois fiches de paie. Si vous avez deux ou trois biens à me proposer aujourd'hui, je préférerais commencer par le moins cher pour comparer, puis monter en gamme si rien ne me convient. Pouvons-nous fixer une visite cette semaine, idéalement jeudi ou vendredi en fin de journée ? Je vous remercie pour votre temps.",
        "alternative_answer": "Bonjour, je suis Karim et je cherche actuellement un logement, parce que je viens d'être muté à Lyon pour mon travail. J'aurais besoin d'emménager assez rapidement, idéalement d'ici la fin du mois prochain. Je cherche un studio ou un petit T1, parce que je vis seul et que je n'ai pas besoin de beaucoup d'espace. En revanche, je tiens à être proche d'une station de métro, parce que je ne veux pas acheter de voiture. Mon budget se situe entre six cent cinquante et sept cent cinquante euros, charges comprises. J'ai plusieurs questions à vous poser. Premièrement, les biens que vous proposez sont-ils déjà meublés, ou plutôt vides ? J'ai une légère préférence pour un meublé, parce que cela me simplifierait l'installation. Deuxièmement, quelle est la durée moyenne entre la visite et la signature du bail dans votre agence ? J'ai besoin de visibilité sur le calendrier. Troisièmement, demandez-vous une caution, et si oui, de combien de mois ? Enfin, est-ce que les frais d'agence sont compris dans le loyer affiché, ou en plus ? J'aimerais bien comparer deux ou trois propositions avant de me décider. Si possible, pourrions-nous organiser des visites samedi matin ? Je vous remercie d'avance pour votre aide.",
        "key_elements_to_cover": [
          "Salutation polie",
          "Description claire du besoin (type de bien, surface, lieu)",
          "Au moins deux contraintes (budget, transports, calendrier)",
          "Au moins trois questions précises",
          "Réaction ou comparaison",
          "Conclusion (visite, suite)"
        ],
        "key_vocabulary": ["louer", "T1, T2, studio", "charges comprises", "bail", "caution", "frais d'agence", "meublé", "desservi"],
        "key_grammar": ["Conditionnel de politesse (je voudrais, j'aurais)", "Interrogation avec inversion ou est-ce que", "Si + présent / présent", "Comparatifs"]
      },
      "evaluation_focus": [
        "Précision des besoins exprimés",
        "Au moins 3 vraies questions (pas seulement oui/non)",
        "Politesse et registre adapté",
        "Capacité à conclure l'échange"
      ]
    },
    {
      "id": "q012",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis responsable d'un centre de formation. Vous cherchez un cours de français du soir. Vous m'expliquez vos besoins, votre niveau et vos contraintes d'emploi du temps.",
      "examiner_role_fr": "Responsable d'un centre de formation",
      "themes": ["formation", "français", "apprentissage"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et objet de la demande",
          "Niveau actuel et objectif visé",
          "Contraintes d'emploi du temps",
          "Questions sur le programme, l'organisation, le coût",
          "Conclusion sur l'inscription ou la suite"
        ],
        "reference_answer": "Bonjour Madame, je m'appelle Amina et je vous contacte parce que je cherche un cours de français du soir pour les prochains mois. Mon objectif principal est de préparer le TCF, parce que j'en ai besoin pour ma demande de naturalisation. J'ai déjà un niveau B1 confirmé, validé l'année dernière, et je voudrais atteindre un B2 solide d'ici cinq mois environ. Concernant mes besoins, je voudrais surtout travailler l'expression écrite et l'expression orale, parce que ce sont mes deux points faibles. La compréhension ne me pose presque pas de problème. Je sais que ce sont les épreuves les plus importantes pour le TCF IRN. Au niveau de mes contraintes, je travaille en journée de huit heures à dix-sept heures, donc je suis seulement disponible le soir, à partir de dix-huit heures trente, et le samedi matin. J'aurais quelques questions à vous poser. Tout d'abord, proposez-vous des groupes de niveau B1 vers B2 spécifiquement orientés vers la préparation du TCF ? Ensuite, à quelle fréquence ces cours ont-ils lieu, et combien de temps dure chaque séance ? Je voudrais aussi savoir si les groupes sont composés de quelques élèves seulement, parce que j'ai déjà fait des cours en grand groupe et je n'ai pas vraiment progressé à l'oral. Enfin, quel est le coût total de la formation et acceptez-vous le règlement en plusieurs fois ou un financement par le CPF ? Si tout cela me convient, je serais prête à m'inscrire dès la prochaine rentrée. Pourriez-vous me dire quelles sont les démarches à suivre pour finaliser l'inscription ?",
        "alternative_answer": "Bonjour, je m'appelle Marco et je cherche des cours de français pour adulte, le soir, après le travail. J'habite en France depuis deux ans et mon niveau actuel se situe autour de A2. Je comprends bien quand on me parle lentement, mais je peine à former des phrases complètes, surtout au passé. Mon objectif est de pouvoir mieux échanger au travail et avec les voisins. Je suis disponible les lundis, mardis et jeudis à partir de dix-neuf heures, mais pas le mercredi parce que je m'occupe de mes enfants. J'ai plusieurs questions. Premièrement, à quel niveau démarrent vos cours ? Avez-vous une classe pour les A2 qui veulent passer au B1 ? Deuxièmement, le cours est-il assuré par un enseignant natif et avec quel type de support pédagogique ? Troisièmement, les inscriptions se font-elles à la séance ou pour un trimestre complet ? Pour ma part, je préférerais m'engager pour une période courte d'abord, pour voir si la méthode me convient. Enfin, quel est votre tarif horaire ? Si vos cours répondent à mes attentes, je suis prêt à commencer dès lundi prochain. Merci de votre temps.",
        "key_elements_to_cover": [
          "Salutation et objet clair",
          "Niveau actuel et objectif précis",
          "Contraintes d'emploi du temps",
          "Au moins trois questions précises",
          "Conclusion concrète (inscription, démarches)"
        ],
        "key_vocabulary": ["formation", "niveau A2/B1/B2", "compréhension orale/écrite", "expression orale/écrite", "groupe de niveau", "tarif", "s'inscrire", "rentrée"],
        "key_grammar": ["Conditionnel (je voudrais, je serais prêt)", "Interrogation", "Cause (parce que, car)", "Pronoms relatifs"]
      },
      "evaluation_focus": [
        "Description claire de la situation linguistique",
        "Contraintes pratiques explicitées",
        "Questions ciblées sur la formation",
        "Engagement final ou plan de suite"
      ]
    },
    {
      "id": "q013",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis conseiller dans une agence de voyages. Vous voulez organiser des vacances à petit budget. Vous m'expliquez ce que vous cherchez et vous comparez plusieurs possibilités.",
      "examiner_role_fr": "Conseiller en agence de voyages",
      "themes": ["voyage", "budget", "vacances"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et description du projet",
          "Contraintes de budget, période et préférences",
          "Demande de propositions",
          "Comparaison des options",
          "Décision préliminaire ou suite"
        ],
        "reference_answer": "Bonjour, je m'appelle Julien et je voudrais organiser des vacances pour la fin du mois de juillet, mais avec un budget assez serré. Nous serons deux adultes, ma compagne et moi, et nous aimerions partir une semaine, idéalement à l'étranger pour changer un peu. Notre budget total est de mille euros pour deux, transport et hébergement compris. Je sais que ce n'est pas énorme, c'est pourquoi je viens vous demander conseil. Concernant les préférences, nous aimons surtout la mer, mais nous sommes aussi ouverts à un séjour culturel, par exemple dans une grande ville d'Europe. Nous ne tenons pas particulièrement aux hôtels haut de gamme : un appartement ou une auberge propre nous convient parfaitement. Quelles destinations pourriez-vous nous proposer dans cette gamme de prix ? Si vous me proposez deux ou trois possibilités, j'aimerais comparer le coût total mais aussi le temps de transport, parce que nous ne voulons pas perdre une journée entière dans les avions. Par exemple, est-ce que partir au Portugal serait plus avantageux que la Croatie à cette période ? Et est-ce que nous pourrions trouver un vol direct, ou faut-il prévoir une escale ? J'aurais aussi une question sur les assurances : sont-elles incluses dans vos formules, ou est-ce qu'il faut les payer en plus ? Si une option me semble vraiment intéressante, je préférerais réserver rapidement, parce que les prix augmentent vite à cette période de l'année. Pourriez-vous me préparer deux propositions par mail d'ici la fin de la semaine, pour que j'en discute avec ma compagne ?",
        "alternative_answer": "Bonjour Madame, je suis Sofia et je voudrais partir en vacances pendant les vacances scolaires d'avril, avec mes deux enfants de huit et onze ans. Mon mari ne pourra pas se libérer, donc je serai seule avec eux. Mon budget est limité à environ huit cents euros pour nous trois, sur cinq nuits, hébergement et trajet inclus. Je préfère rester en France, parce que c'est plus simple avec les enfants. Idéalement, je voudrais un endroit où ils peuvent jouer en extérieur, près de la mer ou de la montagne. Pourriez-vous me proposer plusieurs options ? J'aimerais comparer un séjour dans le Sud-Ouest avec un séjour en Bretagne. Quelle option me reviendrait moins chère, en prenant en compte le train et le logement ? Je voudrais aussi savoir si vous avez des partenariats avec des résidences de vacances qui proposent des réductions famille. Enfin, est-il possible d'annuler sans frais en cas de problème de santé des enfants ? Si une formule me convient vraiment, je suis prête à réserver dès la semaine prochaine, mais je voudrais d'abord recevoir un devis détaillé par mail. Merci pour votre aide.",
        "key_elements_to_cover": [
          "Salutation et présentation du projet",
          "Budget précis et contraintes (durée, accompagnants)",
          "Préférences de destination ou type de séjour",
          "Demande de comparaison entre options",
          "Décision ou suite concrète"
        ],
        "key_vocabulary": ["séjour", "destination", "hébergement", "vol direct", "escale", "devis", "réserver", "annulation", "haut de gamme"],
        "key_grammar": ["Conditionnel (je voudrais, pourriez-vous)", "Comparatifs (plus, moins, aussi)", "Si + présent / conditionnel", "Question avec inversion"]
      },
      "evaluation_focus": [
        "Contraintes budgétaires explicites",
        "Demande de comparaison effective",
        "Vocabulaire du voyage",
        "Conclusion concrète"
      ]
    },
    {
      "id": "q014",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis vendeur dans un magasin d'informatique. Vous cherchez un ordinateur pour travailler et suivre des cours en ligne. Vous m'expliquez vos besoins et votre budget.",
      "examiner_role_fr": "Vendeur en magasin d'informatique",
      "themes": ["technologie", "achat", "études"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et expression du besoin",
          "Usage prévu (travail, études, autres)",
          "Contraintes (portabilité, performance, budget)",
          "Questions techniques précises",
          "Demande de comparaison et suite"
        ],
        "reference_answer": "Bonjour, je viens vous voir parce que je cherche un nouvel ordinateur portable. Mon ordinateur actuel a sept ans, il est devenu très lent, et je commence des études à distance le mois prochain. J'ai donc besoin d'un appareil fiable, capable de tenir au moins quatre ou cinq ans. Je vais l'utiliser principalement pour deux choses : mon travail à temps partiel, qui consiste à rédiger des documents et utiliser des tableurs, et surtout mes cours en ligne, qui demandent souvent des visioconférences pendant deux ou trois heures, parfois en parallèle d'un éditeur de texte ouvert. La portabilité est très importante pour moi parce que je me déplace souvent entre la maison, le travail et la bibliothèque. Idéalement, je voudrais un modèle de treize ou quatorze pouces, léger, avec une bonne autonomie de batterie. Mon budget est d'environ huit cents euros, et je peux monter à neuf cents si l'investissement en vaut vraiment la peine. J'aurais plusieurs questions techniques. Tout d'abord, dans cette gamme de prix, quel processeur me recommanderiez-vous, sachant que je n'ai pas besoin d'une carte graphique puissante ? Ensuite, est-ce que huit gigaoctets de mémoire suffisent pour mon usage, ou faut-il vraiment passer à seize ? Et concernant le stockage, faut-il privilégier un disque SSD plus petit ou un classique plus grand ? J'aimerais aussi savoir quelle est la durée de garantie standard et si vous proposez une extension à un prix raisonnable. Si vous pouviez me montrer deux ou trois modèles qui correspondent à mes besoins, je préférerais comparer en main avant de prendre ma décision aujourd'hui.",
        "alternative_answer": "Bonjour Monsieur, je voudrais acheter un ordinateur, mais je dois vous avouer que je m'y connais peu. Je suis en formation pour devenir secrétaire médicale et je dois pouvoir taper du texte, faire des recherches et suivre des cours en visio plusieurs heures par jour. Je cherche un appareil simple, fiable, et facile à utiliser. Je n'ai pas besoin de jouer ni de faire de la création vidéo. Mon budget se situe entre cinq cents et six cents euros maximum, parce que je dois aussi acheter d'autres fournitures pour mes études. Pourriez-vous me conseiller plusieurs modèles dans cette gamme ? J'ai quelques questions précises. La batterie tient-elle vraiment toute la journée, par exemple six ou sept heures d'utilisation ? Faut-il acheter en plus une suite bureautique comme Word, ou est-ce que des solutions gratuites suffisent ? Préférez-vous un modèle Windows ou ChromeBook pour mon usage ? Enfin, livrez-vous à domicile, ou dois-je tout emporter aujourd'hui ? Si vous me trouvez quelque chose qui correspond, je suis prête à acheter aujourd'hui même.",
        "key_elements_to_cover": [
          "Description précise de l'usage prévu",
          "Contraintes (poids, autonomie, budget)",
          "Au moins trois questions techniques",
          "Demande de comparaison ou démonstration",
          "Décision ou suite"
        ],
        "key_vocabulary": ["ordinateur portable", "processeur", "mémoire (RAM)", "stockage SSD", "autonomie", "garantie", "visioconférence", "fiable"],
        "key_grammar": ["Conditionnel (je voudrais, pourriez-vous)", "Si + imparfait / conditionnel", "Comparatifs", "Pronoms COD/COI"]
      },
      "evaluation_focus": [
        "Description fonctionnelle précise",
        "Contraintes claires",
        "Questions techniques concrètes",
        "Pas seulement oui/non"
      ]
    },
    {
      "id": "q015",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis secrétaire dans un centre médical. Vous voulez prendre un rendez-vous de contrôle. Vous expliquez la situation et vous demandez les informations nécessaires.",
      "examiner_role_fr": "Secrétaire médicale",
      "themes": ["santé", "rendez-vous", "démarches"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et identification",
          "Motif du rendez-vous (contrôle, suivi, urgence relative)",
          "Disponibilités et contraintes",
          "Questions pratiques (préparation, documents, tarifs)",
          "Confirmation et clôture polie"
        ],
        "reference_answer": "Bonjour Madame, je m'appelle Hassan Benali et je voudrais prendre un rendez-vous de contrôle avec le docteur Lambert, qui est mon médecin traitant. C'est pour faire le suivi de ma tension artérielle. La dernière fois que je l'ai vu, c'était il y a six mois, et il m'avait demandé de revenir pour vérifier que mon traitement était toujours bien adapté. Ce n'est pas urgent, mais j'aimerais éviter d'attendre trop longtemps, parce que mes derniers résultats à la pharmacie n'étaient pas tout à fait stables. Concernant mes disponibilités, je travaille du lundi au vendredi, et je peux me libérer assez facilement le mardi ou le jeudi, soit en début de matinée, soit en fin d'après-midi après dix-sept heures. Le mercredi, je préfère éviter, parce que c'est ma journée la plus chargée. J'aurais aussi quelques questions à vous poser. Tout d'abord, faut-il que je vienne à jeun pour ce contrôle ou non ? Je crois que la dernière fois, le médecin avait demandé une prise de sang, donc je préfère vérifier. Ensuite, dois-je apporter des documents particuliers, par exemple les ordonnances précédentes ou les résultats de mes derniers examens ? Et concernant le tarif, est-ce qu'il a changé depuis l'année dernière ? Je vous demande parce que je n'ai pas de mutuelle complémentaire, donc je dois bien prévoir mon budget. Si possible, j'aimerais un rendez-vous dans les deux ou trois prochaines semaines. Pourriez-vous me proposer plusieurs créneaux pour que je choisisse celui qui me convient le mieux ? Je vous remercie beaucoup pour votre aide.",
        "alternative_answer": "Bonjour, je suis madame Dupuis et j'aimerais prendre rendez-vous avec le docteur Aubert pour ma fille de quatre ans. Il s'agit d'un contrôle de routine, prévu chaque année à cette période. Elle se porte très bien, donc rien d'urgent. Je suis disponible plutôt en fin d'après-midi, après seize heures, parce que je viens la chercher à l'école. Le mercredi peut aussi convenir, à n'importe quel moment de la journée. J'ai quelques questions. Faut-il prévoir une carte vitale à son nom, ou seulement la mienne suffit ? Devons-nous apporter le carnet de santé ? Je voulais aussi savoir si le médecin pratique aussi les vaccinations en même temps que la visite, ou si on doit revenir une autre fois. Enfin, en cas d'imprévu, jusqu'à combien d'heures avant peut-on annuler sans frais ? Si vous avez quelque chose la semaine prochaine ou la suivante, ce serait parfait. Je vous remercie de votre aide.",
        "key_elements_to_cover": [
          "Identification claire (nom, lien avec le médecin)",
          "Motif du rendez-vous",
          "Disponibilités précises",
          "Au moins deux questions pratiques",
          "Demande de plusieurs créneaux"
        ],
        "key_vocabulary": ["rendez-vous", "médecin traitant", "suivi", "contrôle", "ordonnance", "à jeun", "mutuelle", "créneau"],
        "key_grammar": ["Conditionnel de politesse", "Falloir + infinitif/que + subjonctif", "Pronoms démonstratifs (celui-là, celle-ci)", "Question avec inversion"]
      },
      "evaluation_focus": [
        "Politesse adaptée au contexte médical",
        "Précision du motif",
        "Disponibilités concrètes",
        "Questions pratiques pertinentes"
      ]
    },
    {
      "id": "q016",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis responsable d'une association sportive. Vous voulez vous inscrire à une activité pour améliorer votre santé. Vous m'expliquez ce que vous recherchez.",
      "examiner_role_fr": "Responsable d'association sportive",
      "themes": ["santé", "sport", "association"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et présentation",
          "Motivation santé / situation actuelle",
          "Préférences et activités envisagées",
          "Questions sur les horaires, l'encadrement, le tarif",
          "Décision ou demande d'essai"
        ],
        "reference_answer": "Bonjour, je suis Claire et je viens vous voir parce que je voudrais reprendre une activité sportive régulière pour améliorer ma santé. Pour vous donner un peu de contexte, je travaille beaucoup assise devant un ordinateur, je suis souvent fatiguée et j'ai pris quelques kilos depuis le confinement. Mon médecin m'a vraiment encouragée à reprendre une activité physique, mais douce au début, parce que cela fait presque trois ans que je n'ai rien pratiqué de régulier. Je viens donc me renseigner sur les activités que vous proposez. Idéalement, je voudrais quelque chose qui me fasse bouger, mais sans risque de blessure, parce que j'ai aussi des douleurs au dos. Je pense par exemple à la natation, au yoga, ou éventuellement au pilates. Je ne suis pas vraiment attirée par les sports collectifs ou de combat, parce que je préfère un cadre calme. J'aurais quelques questions précises. Tout d'abord, quelles activités correspondraient le mieux à mon profil, selon vous ? Ensuite, quels sont les horaires des cours pour adultes en soirée ? Je suis disponible à partir de dix-huit heures trente, du lundi au jeudi. Je voudrais aussi savoir si les groupes sont encadrés par des professionnels diplômés, parce que pour moi c'est important d'avoir quelqu'un qui surveille la posture. Enfin, quel est le tarif d'inscription, et est-il possible de faire un cours d'essai gratuit avant de m'engager pour l'année ? Si une activité me convient vraiment, je serais prête à m'inscrire dès cette semaine.",
        "alternative_answer": "Bonjour, je m'appelle Marc, j'ai cinquante-cinq ans, et je voudrais reprendre une activité physique parce que mon médecin a constaté que mon taux de cholestérol était trop élevé. Il m'a recommandé de pratiquer quelque chose au moins deux fois par semaine. Je n'ai jamais été très sportif, donc je préfère démarrer par quelque chose d'accessible. Je pensais à la marche nordique ou éventuellement au vélo en groupe. Pourriez-vous m'expliquer ce que vous proposez dans ces deux disciplines ? J'ai plusieurs questions pratiques. Premièrement, à quelle fréquence se déroulent les sorties ? Je peux me libérer le samedi matin, et éventuellement le mercredi en fin d'après-midi. Deuxièmement, faut-il avoir un certificat médical pour s'inscrire ? Troisièmement, fournissez-vous le matériel comme les bâtons, ou faut-il acheter le sien ? Enfin, quel est le coût d'une cotisation annuelle dans votre association ? Si une activité correspond à mon niveau, je voudrais commencer dès le mois prochain.",
        "key_elements_to_cover": [
          "Motivation santé clairement expliquée",
          "Préférences et limites physiques",
          "Au moins trois questions pratiques",
          "Demande d'essai ou d'inscription",
          "Politesse"
        ],
        "key_vocabulary": ["activité physique", "encadrement", "cotisation", "cours d'essai", "blessure", "posture", "certificat médical", "sport doux"],
        "key_grammar": ["Conditionnel (je voudrais, je serais prête)", "Subjonctif après 'il faut que'", "Si + imparfait / conditionnel", "Pronoms relatifs"]
      },
      "evaluation_focus": [
        "Motivation santé crédible",
        "Préférences concrètes",
        "Questions pratiques",
        "Conclusion engageante"
      ]
    },
    {
      "id": "q017",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis conseiller emploi. Vous cherchez un travail ou une reconversion. Vous m'expliquez votre profil, vos préférences et les conditions qui sont importantes pour vous.",
      "examiner_role_fr": "Conseiller emploi",
      "themes": ["travail", "emploi", "reconversion"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et présentation rapide du profil",
          "Expérience et compétences principales",
          "Projet professionnel (poste recherché ou reconversion)",
          "Conditions importantes (horaires, lieu, salaire, contrat)",
          "Questions et demande d'accompagnement"
        ],
        "reference_answer": "Bonjour Madame, je m'appelle Yasmine et je viens vous voir pour discuter de mon projet professionnel. Pour me présenter rapidement, j'ai trente-quatre ans et j'ai travaillé pendant huit ans dans le secteur de la restauration, principalement comme serveuse, puis comme chef de rang dans un restaurant gastronomique. Aujourd'hui, je souhaite changer de voie, parce que les horaires du soir et des week-ends sont devenus trop difficiles depuis que j'ai un enfant. J'envisage une reconversion vers un métier administratif, par exemple assistante de direction ou agent d'accueil dans une entreprise. Je sais que mes compétences en relation client, en gestion du stress et en organisation peuvent être valorisées dans ce type de poste. J'ai aussi suivi une formation courte en bureautique l'année dernière, donc je maîtrise bien les outils de base comme Word, Excel et la messagerie professionnelle. Concernant les conditions, plusieurs choses sont importantes pour moi. Tout d'abord, je voudrais des horaires de bureau classiques, du lundi au vendredi, idéalement de neuf heures à dix-sept heures. Ensuite, j'ai besoin d'un poste à moins de quarante minutes de chez moi en transports, parce que je dois aller chercher mon fils à l'école. Enfin, je préférerais un CDI ou au minimum un CDD de six mois, pour avoir une certaine sécurité. J'aurais quelques questions. Existe-t-il des formations financées qui me permettraient de renforcer mon profil avant de postuler ? Pourriez-vous m'aider à reformuler mon CV pour mettre en avant les compétences transférables ? Et est-ce que vous organisez des ateliers de simulation d'entretien ? J'aimerais beaucoup être accompagnée sur la durée pour cette reconversion.",
        "alternative_answer": "Bonjour, je suis Antoine et je suis actuellement en recherche d'emploi depuis deux mois. Je suis ingénieur en mécanique de formation, avec quatre ans d'expérience dans une entreprise automobile. J'ai été licencié dans le cadre d'un plan social. Je cherche maintenant un poste similaire, mais je suis aussi ouvert à des secteurs proches comme l'aéronautique ou les énergies renouvelables. Pour les conditions, je suis assez flexible sur le lieu, à condition que ce soit accessible en train. Je préfère un CDI, mais j'accepterais un CDD si l'entreprise est intéressante. Mon salaire actuel est d'environ trente-huit mille euros bruts par an, et je voudrais ne pas trop descendre en dessous. J'ai quelques questions à vous poser. Avez-vous des offres correspondant à mon profil dans la région actuellement ? Existe-t-il des aides financières pendant la recherche, par exemple pour les déplacements aux entretiens ? Pourriez-vous m'aider à préparer un entretien dans un secteur que je connais moins bien ? Enfin, à quelle fréquence pouvons-nous nous revoir pour faire le point ? Merci pour votre temps.",
        "key_elements_to_cover": [
          "Présentation du profil et de l'expérience",
          "Projet professionnel clair",
          "Au moins trois conditions importantes",
          "Au moins deux questions pratiques",
          "Demande d'accompagnement"
        ],
        "key_vocabulary": ["reconversion", "compétences transférables", "CDI/CDD", "horaires de bureau", "poste", "formation financée", "atelier", "accompagnement"],
        "key_grammar": ["Conditionnel (je voudrais, j'accepterais)", "Si + présent / conditionnel", "Pronoms relatifs (qui, que, dont)", "Subjonctif après 'à condition que'"]
      },
      "evaluation_focus": [
        "Profil et projet clairs",
        "Conditions concrètes et hiérarchisées",
        "Questions sur l'accompagnement",
        "Vocabulaire professionnel"
      ]
    },
    {
      "id": "q018",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis employé à la mairie. Vous voulez participer à une activité locale pour rencontrer des habitants. Vous me demandez des informations et vous expliquez vos attentes.",
      "examiner_role_fr": "Employé municipal",
      "themes": ["vie locale", "intégration", "associations"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et explication de la démarche",
          "Profil personnel et raisons de l'envie de s'investir",
          "Préférences (type d'activité, public)",
          "Questions concrètes (quand, où, comment, coût)",
          "Suite (inscription, contacts)"
        ],
        "reference_answer": "Bonjour Monsieur, je m'appelle Léa et je viens vous voir parce que je viens d'emménager dans la ville il y a trois mois et j'aimerais beaucoup rencontrer d'autres habitants. Je travaille à distance, donc je passe la plupart de mes journées seule à la maison, et j'ai vraiment besoin d'élargir mon cercle social en dehors du travail. Je me suis dit que la mairie pourrait peut-être m'orienter vers des activités locales ouvertes à tous. Pour vous donner un peu plus de contexte, j'ai trente ans, je n'ai pas d'enfants, et je suis disponible surtout le soir en semaine et le week-end. Je suis ouverte à beaucoup de choses : un atelier créatif, un club de lecture, une association de quartier, ou même du bénévolat ponctuel. L'important pour moi, c'est de trouver une activité régulière, dans une ambiance conviviale, où je puisse rencontrer des gens variés, pas uniquement de mon âge. J'aurais plusieurs questions à vous poser. Tout d'abord, existe-t-il une liste officielle des associations locales que je pourrais consulter ? Si oui, est-elle disponible en ligne ou faut-il que je vienne la récupérer ici ? Ensuite, organisez-vous des événements publics réguliers, comme des fêtes de quartier ou des marchés conviviaux, où l'on peut facilement faire connaissance ? Je voudrais aussi savoir si la ville propose des activités gratuites pour les nouveaux habitants, par exemple une visite guidée ou une journée d'accueil. Enfin, à qui dois-je m'adresser pour proposer mon aide en tant que bénévole ? Si vous avez un nom de contact ou un mail, ce serait parfait. Je vous remercie beaucoup pour vos conseils.",
        "alternative_answer": "Bonjour, je suis monsieur Diallo et j'aimerais m'investir dans la vie locale, parce que je vis dans la commune depuis longtemps mais je connais peu de monde. Je suis à la retraite depuis l'année dernière et j'ai du temps libre. Je voudrais surtout aider, par exemple en participant à des actions pour les personnes âgées isolées ou pour soutenir les écoles du quartier. Pourriez-vous me dire quelles associations sont actives dans ces domaines ? Y a-t-il des réunions publiques régulières où l'on peut s'informer et rencontrer les responsables ? Je voudrais aussi savoir si la mairie propose des formations courtes pour devenir bénévole, par exemple sur l'écoute ou l'accompagnement. Enfin, existe-t-il un magazine ou une lettre d'information municipale qui parle des activités à venir ? Si vous avez des contacts à me transmettre, je suis prêt à les appeler dès cette semaine pour me proposer.",
        "key_elements_to_cover": [
          "Démarche d'intégration claire",
          "Profil personnel (situation, disponibilités)",
          "Au moins trois questions précises",
          "Demande d'orientation et de contacts",
          "Politesse et conclusion"
        ],
        "key_vocabulary": ["s'investir", "vie locale", "association", "bénévolat", "événement public", "convivial", "élargir son cercle", "se renseigner"],
        "key_grammar": ["Conditionnel (j'aimerais, pourriez-vous)", "Subjonctif (où je puisse)", "Si + présent / présent", "Question avec inversion"]
      },
      "evaluation_focus": [
        "Démarche claire et personnelle",
        "Questions ciblées sur la vie locale",
        "Vocabulaire de la citoyenneté",
        "Demande de contacts concrets"
      ]
    },
    {
      "id": "q019",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis conseiller mobilité. Vous cherchez la meilleure solution pour vos déplacements quotidiens. Vous comparez plusieurs options et vous me dites ce qui est le plus pratique pour vous.",
      "examiner_role_fr": "Conseiller mobilité",
      "themes": ["transports", "mobilité", "vie quotidienne"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et description de la situation",
          "Trajet quotidien (lieu, distance, fréquence)",
          "Options envisagées et critères",
          "Questions sur les coûts, les abonnements, les aides",
          "Conclusion sur la solution préférée"
        ],
        "reference_answer": "Bonjour, je m'appelle Tom et je viens vous voir parce que je dois trouver la meilleure solution pour mes déplacements entre mon domicile et mon lieu de travail. J'habite dans la banlieue ouest et je travaille dans le centre-ville. La distance est d'environ douze kilomètres, et je fais ce trajet cinq jours par semaine. En ce moment, j'utilise ma voiture personnelle, mais cela me pose plusieurs problèmes. Premièrement, le carburant et le stationnement deviennent vraiment chers. Deuxièmement, il y a souvent des bouchons, donc je perds beaucoup de temps. Troisièmement, je ne suis pas à l'aise avec mon impact écologique. Je voudrais donc envisager d'autres options. J'ai trois pistes en tête : prendre les transports en commun, qui combinent bus et tramway, utiliser un vélo électrique, ou passer au covoiturage avec un collègue qui habite dans le même quartier. Pour comparer ces options, j'ai plusieurs questions à vous poser. Tout d'abord, combien coûte un abonnement annuel pour les transports en commun, et y a-t-il une aide de l'employeur sur ce type de dépense ? Ensuite, la ville propose-t-elle un service de location de vélos électriques à long terme, et si oui, à quel tarif ? Pour le covoiturage, existe-t-il une plateforme officielle ou un système d'aide entre collègues ? Enfin, quelles sont, à votre avis, les options les plus pratiques pour quelqu'un qui doit aussi parfois transporter du matériel professionnel un peu encombrant ? Pour l'instant, je penche plutôt vers une combinaison vélo électrique et transports en commun, mais je suis ouvert à vos conseils.",
        "alternative_answer": "Bonjour, je suis Aïcha et je voudrais discuter de mes déplacements quotidiens avec mes deux enfants. Je dois les déposer à l'école avant d'aller à mon travail, qui se trouve à environ huit kilomètres de chez moi. Actuellement, j'utilise ma voiture, mais elle est vieille et coûteuse. Je voudrais comparer plusieurs solutions. Pourriez-vous m'expliquer s'il existe un bus qui passe par l'école et le centre-ville ? Si oui, à quelle fréquence circule-t-il le matin ? J'ai aussi entendu parler de vélos cargos qu'on peut louer pour les familles ; est-ce que la ville propose ce service ? Quelles aides sont disponibles pour aider à financer un abonnement transport pour les familles ? Existe-t-il un tarif réduit ou une carte famille ? Pour l'instant, je penche pour les transports en commun, à condition que les horaires soient compatibles avec ceux de l'école. Pourriez-vous me donner des conseils précis sur les démarches à suivre ?",
        "key_elements_to_cover": [
          "Description précise du trajet et des contraintes",
          "Au moins deux options comparées",
          "Critères de comparaison explicites",
          "Questions sur les coûts et les aides",
          "Conclusion sur la préférence"
        ],
        "key_vocabulary": ["trajet", "transports en commun", "covoiturage", "vélo électrique", "abonnement", "aide financière", "bouchons", "impact écologique"],
        "key_grammar": ["Conditionnel", "Comparatifs (plus, moins, aussi)", "Si + présent / présent", "Pronoms démonstratifs"]
      },
      "evaluation_focus": [
        "Comparaison effective de plusieurs options",
        "Critères clairs",
        "Questions financières concrètes",
        "Préférence justifiée"
      ]
    },
    {
      "id": "q020",
      "section": "expression_orale",
      "task_number": 2,
      "task_id": "oral_task_2",
      "task_type_fr": "Interaction / jeu de rôle",
      "question": "Je suis responsable d'un service Internet. Vous avez besoin d'un abonnement fiable pour télétravailler à domicile. Vous me décrivez vos besoins et vous posez des questions.",
      "examiner_role_fr": "Responsable d'un service Internet",
      "themes": ["technologie", "télétravail", "service"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 240, "ideal": 320, "max": 420 },
        "structure": [
          "Salutation et raison de la demande",
          "Usage prévu (visio, fichiers, télétravail)",
          "Contraintes techniques (foyer, équipements, lieu)",
          "Questions précises (débit, garantie, prix, délai)",
          "Décision ou prochaine étape"
        ],
        "reference_answer": "Bonjour, je viens vous voir parce que je dois changer mon abonnement Internet rapidement. Mon offre actuelle ne tient plus la route depuis que je suis passé en télétravail à temps complet. Concrètement, je passe environ six heures par jour en visioconférence avec mes collègues et mes clients, et j'ai régulièrement besoin de transférer ou télécharger des fichiers volumineux, parfois plusieurs gigaoctets. Je dois donc trouver une connexion fiable, stable et avec un débit adapté. Pour le contexte, j'habite dans un appartement en centre-ville, donc je sais que la fibre est disponible dans mon immeuble. Nous sommes deux dans le foyer, et ma compagne fait également du télétravail, ce qui veut dire que nous utilisons souvent Internet en parallèle. Nous avons aussi une télévision connectée et plusieurs objets domotiques. J'aurais plusieurs questions à vous poser. Tout d'abord, quelles offres fibre proposez-vous pour un usage intensif comme le mien ? Je voudrais surtout connaître le débit garanti et pas seulement le débit théorique. Ensuite, combien de temps faut-il en moyenne entre la souscription et l'installation effective à mon domicile ? Je ne peux pas me permettre d'être coupé plus de quelques jours. Je voudrais aussi savoir si vous proposez un service d'assistance technique réactif en cas de panne, et sous quel délai vous intervenez en moyenne. Enfin, quel est le prix mensuel total, frais d'installation compris, et y a-t-il un engagement de longue durée ? Si l'offre me convient, je serais prêt à signer aujourd'hui même, à condition que l'installation soit possible avant la fin du mois.",
        "alternative_answer": "Bonjour Madame, je vous explique ma situation : nous venons d'emménager dans une maison en zone rurale et je dois trouver un abonnement Internet pour notre famille. Je travaille de chez moi trois jours par semaine, et mes deux adolescents font des cours en ligne et regardent des contenus en streaming le soir. Je voudrais donc une connexion suffisamment puissante pour que nous puissions tous l'utiliser en même temps. Pourriez-vous me dire quels services sont disponibles à mon adresse ? Avez-vous la fibre dans ce secteur, ou faut-il passer par une solution alternative comme la 4G fixe ? Quel est le débit réel que je peux espérer en pratique, et pas en théorie ? Je voudrais aussi connaître les frais d'installation et la durée d'engagement minimum. Y a-t-il une période d'essai pendant laquelle on peut résilier sans frais ? Enfin, quel est le service client en cas de panne, parce que je ne peux pas me permettre de rester sans Internet plusieurs jours. Si tout est clair, je voudrais souscrire dans les plus brefs délais.",
        "key_elements_to_cover": [
          "Usage intensif clairement justifié",
          "Détail du foyer (nombre, équipements)",
          "Au moins trois questions techniques",
          "Question sur les délais et le SAV",
          "Décision conditionnée"
        ],
        "key_vocabulary": ["abonnement", "fibre", "débit", "visioconférence", "installation", "engagement", "service après-vente", "panne"],
        "key_grammar": ["Conditionnel (je voudrais, je serais prêt)", "Si + présent / présent", "Subjonctif après 'à condition que'", "Question complexe (quel, lequel)"]
      },
      "evaluation_focus": [
        "Description technique précise",
        "Questions ciblées et professionnelles",
        "Vocabulaire technique adapté",
        "Décision conditionnelle"
      ]
    },
    {
      "id": "q021",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Le télétravail est-il une bonne solution pour mieux vivre et mieux travailler ? Pourquoi ?",
      "themes": ["travail", "télétravail", "équilibre vie professionnelle"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation de la question + position claire",
          "Premier argument + exemple",
          "Deuxième argument + exemple",
          "Concession ou nuance",
          "Conclusion"
        ],
        "reference_answer": "La question du télétravail est devenue centrale ces dernières années, surtout depuis la crise sanitaire. À mon avis, le télétravail est globalement une bonne solution pour mieux vivre et mieux travailler, à condition d'être pratiqué de manière équilibrée et non à temps complet. Mon premier argument concerne l'organisation personnelle. Le télétravail permet de gagner un temps précieux sur les trajets quotidiens. Par exemple, dans une grande ville comme Paris, beaucoup de salariés perdent deux heures par jour dans les transports. Quand on télétravaille, on peut utiliser ce temps pour faire du sport, cuisiner sainement, s'occuper de ses enfants ou se reposer. C'est un vrai gain de qualité de vie. Mon deuxième argument concerne la concentration et la productivité. Pour de nombreuses tâches qui demandent de la réflexion ou de la rédaction, travailler chez soi, dans un environnement calme, est souvent plus efficace qu'un bureau bruyant ou une réunion qui s'enchaîne. Personnellement, je remarque que je termine certains rapports beaucoup plus vite à la maison qu'au bureau. Cependant, je pense qu'il faut nuancer. Le télétravail à temps complet présente aussi des risques. On peut se sentir isolé, perdre le lien avec ses collègues, et avoir du mal à séparer la vie privée de la vie professionnelle. De plus, certains métiers, notamment dans la santé ou l'industrie, ne peuvent tout simplement pas se faire à distance. Pour conclure, je dirais que le télétravail est une bonne solution, mais sous condition. La meilleure formule est, selon moi, un modèle hybride avec deux ou trois jours à distance et le reste au bureau. C'est cet équilibre qui permet vraiment de mieux vivre et de mieux travailler.",
        "alternative_answer": "Le télétravail s'est imposé dans nos vies récemment et il fait beaucoup débat. Pour ma part, je ne suis pas entièrement convaincu que ce soit toujours une bonne solution, et je pense que cela dépend beaucoup du contexte personnel. Mon premier argument est que le télétravail peut effectivement améliorer la qualité de vie des salariés, parce qu'il réduit le temps de transport et offre plus de flexibilité. Par exemple, une amie à moi peut récupérer ses enfants à l'école sans stress depuis qu'elle est en télétravail trois jours par semaine. Cependant, mon deuxième argument est plus critique. Pour beaucoup de personnes, surtout celles qui vivent dans de petits appartements, ou qui débutent dans leur carrière, le télétravail peut devenir une source d'isolement et de mauvaise organisation. Sans cadre fixe, on travaille parfois plus longtemps, on prend moins de pauses, et l'on se coupe des collègues. C'est une vraie difficulté pour la santé mentale. Il est vrai aussi que certaines entreprises imposent maintenant des modèles hybrides obligatoires, sans tenir compte des préférences individuelles, ce qui crée parfois de la frustration. Pour conclure, je pense que le télétravail peut être une bonne solution, mais à condition d'être bien encadré, choisi librement, et de ne pas dépasser un certain nombre de jours par semaine. Sinon, il peut faire plus de mal que de bien.",
        "key_elements_to_cover": [
          "Position claire dès le début",
          "Deux arguments distincts (pas la même idée reformulée)",
          "Au moins un exemple concret",
          "Une nuance ou concession",
          "Conclusion synthétique"
        ],
        "key_vocabulary": ["télétravail", "modèle hybride", "isolement", "productivité", "équilibre vie pro/perso", "trajet", "flexibilité", "encadrement"],
        "key_grammar": ["Conditionnel (je dirais, on pourrait)", "Subjonctif après 'à condition que', 'pour que'", "Connecteurs argumentatifs", "Cause/conséquence"]
      },
      "evaluation_focus": [
        "Position claire dès l'introduction",
        "Deux arguments réellement distincts",
        "Présence d'une nuance",
        "Vocabulaire du monde du travail"
      ]
    },
    {
      "id": "q022",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Selon vous, les démarches administratives en ligne facilitent-elles vraiment la vie quotidienne ? Pourquoi ?",
      "themes": ["démarches administratives", "numérique", "vie quotidienne"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position",
          "Argument pratique en faveur (gain de temps, accessibilité)",
          "Argument en faveur (suivi, traçabilité)",
          "Limite ou nuance (fracture numérique, complexité)",
          "Conclusion équilibrée"
        ],
        "reference_answer": "La numérisation des services publics est aujourd'hui une réalité dans presque tous les domaines : impôts, sécurité sociale, préfecture, mairie. La question est de savoir si cela a vraiment simplifié notre quotidien. À mon avis, les démarches en ligne facilitent globalement la vie, mais à condition de savoir les utiliser et d'avoir accès à un bon équipement. Mon premier argument est le gain de temps considérable. Avant, il fallait souvent prendre une demi-journée de congé, faire la queue à un guichet, parfois revenir plusieurs fois pour fournir un document oublié. Aujourd'hui, on peut renouveler une carte grise, déclarer ses revenus ou prendre un rendez-vous pour un titre de séjour depuis chez soi, en quelques minutes. C'est un progrès indéniable. Mon deuxième argument concerne la traçabilité. Quand on fait une démarche en ligne, on reçoit en général une confirmation par mail, un numéro de dossier, parfois la possibilité de suivre l'état d'avancement étape par étape. C'est rassurant et cela évite beaucoup de pertes de documents. Cependant, il faut reconnaître que ces démarches en ligne posent de vrais problèmes pour certaines personnes. Les seniors, les personnes en situation de précarité ou celles qui ne maîtrisent pas le français écrit peuvent se retrouver complètement perdues face à un formulaire complexe. Quand un site est en panne ou qu'on ne sait pas où trouver un document, il devient difficile d'obtenir de l'aide. C'est ce qu'on appelle la fracture numérique. Pour conclure, je dirais que les démarches en ligne représentent un vrai progrès pour la majorité des gens, mais qu'elles ne doivent pas remplacer entièrement l'accueil physique. Il faut conserver des points de contact pour celles et ceux qui en ont besoin.",
        "alternative_answer": "Les démarches administratives en ligne se sont multipliées ces dernières années et il faut bien admettre qu'elles changent profondément notre rapport à l'administration. Personnellement, je pense que c'est plutôt positif, mais le bilan reste nuancé. Premièrement, cela rend les démarches accessibles à tous moments. On peut effectuer une demande à minuit ou un dimanche, ce qui est précieux pour les personnes qui travaillent en horaires décalés. Deuxièmement, cela diminue le stress lié aux longues files d'attente, qui restent un mauvais souvenir pour beaucoup d'entre nous. Cependant, il faut reconnaître que tous les sites ne se valent pas. Certains sont mal conçus, lents ou difficiles à comprendre. Quand on tombe sur un problème technique, il est souvent compliqué de joindre quelqu'un par téléphone pour obtenir de l'aide. Cela peut devenir très frustrant et finir par faire perdre encore plus de temps qu'une démarche traditionnelle. Pour conclure, je pense qu'on est sur la bonne voie, mais que beaucoup de progrès restent à faire pour rendre ces outils vraiment accessibles à toute la population.",
        "key_elements_to_cover": [
          "Position claire",
          "Deux arguments en faveur",
          "Au moins une vraie limite",
          "Exemples concrets de la vie quotidienne",
          "Conclusion équilibrée"
        ],
        "key_vocabulary": ["démarches administratives", "fracture numérique", "guichet", "traçabilité", "renouveler", "déclarer", "site en panne", "accessible"],
        "key_grammar": ["Conditionnel", "Subjonctif", "Cause (parce que, car)", "Opposition (cependant, en revanche)"]
      },
      "evaluation_focus": [
        "Argumentation équilibrée",
        "Référence à des situations concrètes",
        "Vocabulaire administratif",
        "Conclusion claire"
      ]
    },
    {
      "id": "q023",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Faut-il limiter l'usage du téléphone portable à l'école ou dans les lieux d'étude ? Pourquoi ?",
      "themes": ["éducation", "téléphone portable", "concentration"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position",
          "Argument concentration et apprentissages",
          "Argument lien social et bien-être",
          "Nuance (usage encadré, pas interdit)",
          "Conclusion"
        ],
        "reference_answer": "La question du téléphone portable à l'école fait débat dans presque tous les pays. Pour ma part, je pense clairement qu'il faut limiter, voire interdire, l'usage du téléphone portable dans les lieux d'étude, du moins pour les plus jeunes. Mon premier argument concerne la concentration et la qualité des apprentissages. Plusieurs études récentes montrent que la simple présence d'un téléphone, même éteint, sur un bureau, diminue les performances cognitives. Les notifications, les messages et les réseaux sociaux sont des sources permanentes de distraction. Personnellement, j'ai vu des collégiens incapables de finir un exercice de mathématiques sans regarder leur écran toutes les cinq minutes. C'est un vrai problème pour leurs résultats scolaires. Mon deuxième argument concerne le lien social entre élèves. Quand chacun reste sur son téléphone pendant la récréation, il y a moins de discussions, moins de jeux, et plus d'isolement. Le climat scolaire en souffre, et cela peut même favoriser le harcèlement à travers les réseaux sociaux. Limiter le téléphone à l'école aide donc à préserver une vraie vie collective. Cependant, je pense qu'il faut nuancer. Interdire totalement le téléphone n'est pas toujours possible, ni souhaitable. À l'université, par exemple, les étudiants en ont parfois besoin pour prendre des notes, accéder aux supports de cours ou contacter un proche. La règle doit donc s'adapter à l'âge et au type d'établissement. Pour conclure, je suis favorable à une limitation stricte au collège et au lycée, mais je préfère un encadrement plus souple, basé sur la responsabilité, à l'université ou dans les formations pour adultes.",
        "alternative_answer": "Le téléphone portable est devenu un objet incontournable, y compris pour les plus jeunes. Faut-il en limiter l'usage à l'école ? À mon avis, oui, mais avec mesure. Tout d'abord, le téléphone est un facteur évident de distraction. Pendant un cours, il suffit d'une notification pour qu'un élève décroche complètement. Cela rend le travail des enseignants plus difficile et nuit à l'apprentissage. Ensuite, l'usage non contrôlé peut favoriser le cyberharcèlement, surtout pendant les pauses. Beaucoup de cas commencent par des messages échangés en cours de journée. Limiter l'usage à l'école aide à protéger les élèves les plus fragiles. Cependant, il ne faut pas être trop strict. Le téléphone peut aussi être un outil pédagogique précieux pour faire des recherches rapides, écouter une vidéo en langue étrangère ou travailler en groupe. La meilleure solution est donc d'avoir un cadre clair : interdiction pendant les cours et les récréations, mais usage autorisé sous la supervision de l'enseignant lorsqu'il en a besoin. Pour conclure, oui, il faut limiter, mais sans diaboliser un outil qui fait partie de la vie d'aujourd'hui.",
        "key_elements_to_cover": [
          "Position claire (pour ou contre la limitation)",
          "Argument scolaire/cognitif",
          "Argument social",
          "Nuance ou exception",
          "Conclusion équilibrée"
        ],
        "key_vocabulary": ["concentration", "distraction", "harcèlement", "lien social", "encadrement", "outil pédagogique", "réseaux sociaux", "récréation"],
        "key_grammar": ["Subjonctif après 'il faut que'", "Conditionnel", "Opposition", "Cause/conséquence"]
      },
      "evaluation_focus": [
        "Position assumée",
        "Arguments distincts",
        "Vocabulaire éducatif et numérique",
        "Capacité à nuancer"
      ]
    },
    {
      "id": "q024",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Les réseaux sociaux rapprochent-ils les gens ou les isolent-ils davantage ? Donnez votre opinion.",
      "themes": ["réseaux sociaux", "lien social", "société"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position nuancée",
          "Argument 'rapprochement' (distance, communautés)",
          "Argument 'isolement' (superficialité, addiction)",
          "Synthèse personnelle",
          "Conclusion"
        ],
        "reference_answer": "La question des réseaux sociaux est devenue incontournable, et chaque génération en perçoit les effets différemment. Personnellement, je pense que les réseaux sociaux peuvent rapprocher les gens, mais qu'ils tendent malheureusement, dans la pratique, à les isoler davantage. Mon premier argument est qu'il est vrai que les réseaux sociaux permettent de garder le contact avec des personnes éloignées. Pour quelqu'un comme moi, qui vit loin de sa famille, recevoir des photos, échanger des messages quotidiens ou faire un appel vidéo à mes parents est un vrai bonheur. Sans ces outils, beaucoup de relations à distance s'éteindraient lentement. Les réseaux peuvent aussi créer des communautés autour d'intérêts communs, et permettre à des personnes isolées de trouver des soutiens, par exemple sur des sujets de santé. Cependant, mon deuxième argument est que, dans la vie quotidienne, ces outils tendent à appauvrir les relations réelles. On voit aujourd'hui beaucoup de gens dans les transports, dans les cafés, ou même à table, le regard rivé sur leur écran, plutôt qu'en train de discuter avec ceux qui sont à côté d'eux. Les jeunes en particulier sont exposés à une comparaison permanente avec des vies idéalisées, ce qui peut générer un sentiment de solitude et un manque d'estime de soi. Il est vrai que tout dépend de l'usage qu'on en fait. Quelqu'un qui utilise les réseaux comme un complément à sa vie sociale en tirera des bénéfices ; quelqu'un qui les utilise comme un substitut risque au contraire de s'isoler davantage. Pour conclure, je pense que les réseaux sociaux ne sont pas mauvais en soi, mais qu'il faut apprendre à les utiliser avec discernement, sinon le risque d'isolement est bien réel.",
        "alternative_answer": "La question des réseaux sociaux est très débattue. À mon avis, ils ne rapprochent ni n'isolent automatiquement : tout dépend de la manière dont on s'en sert. D'abord, il est indéniable qu'ils créent des liens. Par exemple, ils permettent à des familles dispersées dans plusieurs pays de rester en contact, ou à des personnes qui partagent une passion de se retrouver dans des groupes spécialisés. C'est un atout considérable, surtout pour ceux qui vivent loin de leurs proches. Cependant, j'ai aussi observé que beaucoup de personnes finissent par préférer les échanges en ligne aux rencontres réelles, ce qui peut appauvrir leur vie sociale. Plus grave encore, la pression des images parfaites diffusées sur ces plateformes peut nuire à l'estime de soi, surtout chez les adolescents. Pour conclure, je pense que les réseaux sociaux sont des outils puissants, mais à double tranchant. Tout dépend de la place qu'on leur laisse dans nos journées. Ils ne doivent pas remplacer les vrais contacts, sinon ils finissent par nous éloigner les uns des autres.",
        "key_elements_to_cover": [
          "Position assumée",
          "Argument en faveur (lien à distance, communautés)",
          "Argument contre (isolement, comparaison, addiction)",
          "Référence à un usage concret",
          "Conclusion équilibrée"
        ],
        "key_vocabulary": ["réseaux sociaux", "lien social", "isolement", "communauté", "estime de soi", "comparaison", "écran", "à distance"],
        "key_grammar": ["Conditionnel", "Subjonctif (sans que, pour que)", "Comparatifs", "Connecteurs d'opposition"]
      },
      "evaluation_focus": [
        "Position personnelle claire",
        "Arguments distincts",
        "Vocabulaire psychosocial",
        "Capacité à nuancer"
      ]
    },
    {
      "id": "q025",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Apprendre en ligne peut-il remplacer complètement les cours en présentiel ? Pourquoi ?",
      "themes": ["éducation", "apprentissage en ligne", "présentiel"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position",
          "Avantages du présentiel (interaction, motivation)",
          "Avantages du en ligne (flexibilité, ressources)",
          "Conclusion : modèle hybride ou non",
          "Synthèse"
        ],
        "reference_answer": "L'apprentissage en ligne s'est énormément développé, surtout depuis la pandémie, et beaucoup d'écoles et d'universités proposent maintenant des cours à distance. La question est de savoir si cette modalité peut totalement remplacer le présentiel. À mon avis, non, l'apprentissage en ligne ne peut pas remplacer complètement les cours en présentiel, même s'il les enrichit beaucoup. Mon premier argument concerne l'interaction humaine. Dans une salle de classe, l'enseignant peut percevoir si les élèves comprennent ou pas, adapter son explication en temps réel, encourager celui qui n'ose pas parler. À distance, ces signaux sont beaucoup plus difficiles à lire. Pour les jeunes apprenants, mais aussi pour ceux qui apprennent une langue étrangère par exemple, cette interaction directe est essentielle. Mon deuxième argument concerne la motivation. Étudier seul devant un écran demande énormément de discipline. De nombreuses personnes qui se sont inscrites à des cours en ligne pendant la pandémie ont abandonné en cours de route, parce qu'elles n'avaient personne à côté d'elles pour les soutenir. La dimension collective d'une classe joue un vrai rôle dans la persévérance. Cependant, je reconnais que l'apprentissage en ligne a des atouts considérables. Il offre une grande flexibilité, permet d'accéder à des contenus de qualité depuis n'importe où, et d'apprendre à son rythme. Pour des adultes en formation continue, c'est souvent la seule solution réaliste. Pour conclure, je dirais que la meilleure approche est sans doute hybride : utiliser le numérique pour les supports et la flexibilité, mais conserver des moments en présentiel pour l'interaction et l'accompagnement. Le tout en ligne ne peut convenir qu'à un public déjà très autonome.",
        "alternative_answer": "L'apprentissage en ligne s'est imposé comme une vraie alternative pour beaucoup d'apprenants. Pour ma part, je pense qu'il représente une formidable opportunité, mais qu'il ne peut pas remplacer entièrement les cours en présentiel. D'abord, le présentiel apporte une dynamique de groupe irremplaçable. Quand on étudie ensemble dans une salle, on peut s'entraider, poser des questions spontanément et bénéficier de l'énergie collective. C'est particulièrement vrai pour des matières pratiques ou créatives. Ensuite, le présentiel facilite la création de liens sociaux durables, qui peuvent être très importants pour la vie professionnelle ou personnelle. Cependant, il serait injuste de minimiser les atouts de l'apprentissage en ligne. Il rend l'éducation accessible à des personnes qui ne pourraient pas se déplacer, à cause d'un handicap, d'un travail, ou de leur lieu de vie. Il permet aussi d'apprendre à son propre rythme, ce qui peut convenir parfaitement à certains profils. Pour conclure, je pense que la meilleure formule est une combinaison des deux : utiliser le en ligne pour la souplesse et le présentiel pour la richesse humaine.",
        "key_elements_to_cover": [
          "Position claire",
          "Au moins un avantage du présentiel",
          "Au moins un avantage du en ligne",
          "Reconnaissance équilibrée",
          "Conclusion (souvent : modèle hybride)"
        ],
        "key_vocabulary": ["apprentissage à distance", "présentiel", "interaction", "autonomie", "flexibilité", "discipline", "modèle hybride", "abandon"],
        "key_grammar": ["Conditionnel", "Subjonctif (pour que)", "Comparatifs", "Connecteurs argumentatifs"]
      },
      "evaluation_focus": [
        "Position assumée",
        "Équilibre des arguments",
        "Vocabulaire pédagogique",
        "Solution synthétique"
      ]
    },
    {
      "id": "q026",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Est-il préférable d'habiter près de son travail, même dans un logement plus petit ? Pourquoi ?",
      "themes": ["logement", "travail", "qualité de vie"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position",
          "Argument 'gain de temps / qualité de vie'",
          "Argument 'environnement / santé'",
          "Nuance (taille du logement, famille)",
          "Conclusion personnelle"
        ],
        "reference_answer": "La question du logement face au travail est un vrai dilemme, surtout dans les grandes villes où les loyers sont très élevés. Personnellement, je pense qu'il est globalement préférable d'habiter près de son travail, même au prix d'un logement plus petit, à condition que la situation familiale le permette. Mon premier argument concerne la qualité de vie au quotidien. Quand on vit à proximité de son lieu de travail, on gagne énormément de temps : pas d'embouteillages, pas de trajets en train à rallonge, pas de stress avant et après la journée de travail. Ce temps libéré peut être consacré à la famille, au sport, à la lecture ou simplement au repos. À long terme, cela a un impact positif sur la santé physique et mentale. Mon deuxième argument concerne l'environnement et la santé collective. Vivre près de son travail permet souvent de se déplacer à pied ou à vélo, ce qui réduit la pollution et l'encombrement des routes. Cela contribue, à petite échelle, à un mode de vie plus durable. Cependant, il faut nuancer. Pour une famille avec deux ou trois enfants, vivre dans un appartement très petit en centre-ville n'est pas toujours envisageable. Le manque d'espace peut devenir source de tensions, et les enfants ont parfois besoin de jardins, d'écoles bien notées ou d'activités plus accessibles en banlieue. Le calcul est donc différent selon les profils. Pour conclure, je pense que pour une personne seule ou un jeune couple, vivre près de son travail dans un petit logement est souvent une excellente idée. Pour une famille en revanche, il est légitime d'arbitrer en faveur de l'espace et d'accepter un trajet plus long. Tout dépend de la priorité du moment.",
        "alternative_answer": "Habiter près de son travail, même dans un logement plus petit, est un choix qui mérite réflexion. À mon avis, c'est une option intéressante, mais qui n'est pas adaptée à tout le monde. Premier point en sa faveur : le gain de temps quotidien. Ne plus passer une heure ou deux dans les transports change vraiment la qualité d'une journée. On est moins fatigué, on a plus d'énergie pour ses proches et ses loisirs. Deuxième point : on dépense beaucoup moins en transport, ce qui compense en partie le loyer plus élevé du centre-ville. Cependant, il faut reconnaître que la taille du logement compte beaucoup. Vivre à quatre dans trente-cinq mètres carrés peut devenir invivable à long terme. De plus, en banlieue, on a souvent accès à des espaces verts, à des écoles plus calmes, et à un meilleur cadre de vie pour des enfants. Pour conclure, le choix dépend vraiment du moment de vie. Une personne seule ou un jeune couple gagnera à habiter en centre-ville, alors qu'une famille devra arbitrer plus finement entre temps de transport et qualité de vie quotidienne.",
        "key_elements_to_cover": [
          "Position claire et nuancée",
          "Argument 'temps / santé'",
          "Argument 'environnement' ou 'argent'",
          "Limite (famille, espace)",
          "Conclusion adaptée au contexte"
        ],
        "key_vocabulary": ["proximité", "trajet", "qualité de vie", "loyer", "espace", "centre-ville", "banlieue", "embouteillages"],
        "key_grammar": ["Conditionnel", "Subjonctif (à condition que)", "Comparatifs", "Connecteurs"]
      },
      "evaluation_focus": [
        "Position personnelle nuancée",
        "Arguments distincts",
        "Vocabulaire urbain",
        "Conclusion contextualisée"
      ]
    },
    {
      "id": "q027",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Les petits commerces sont-ils plus utiles que les grands supermarchés dans un quartier ? Pourquoi ?",
      "themes": ["commerce", "vie de quartier", "consommation"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position",
          "Argument 'lien social / vie locale'",
          "Argument 'qualité / proximité'",
          "Nuance (prix, choix)",
          "Conclusion"
        ],
        "reference_answer": "Le débat entre petits commerces et grands supermarchés revient souvent dans les discussions sur la vie de quartier. Pour ma part, je pense que les petits commerces sont plus utiles que les supermarchés dans un quartier, même s'ils ne peuvent pas tout remplacer. Mon premier argument concerne le lien social. Dans un petit commerce, on connaît souvent le commerçant par son prénom, on échange quelques mots, on prend des nouvelles. Pour les personnes seules ou âgées, ce sont parfois les seules conversations de la journée. C'est un véritable rôle social, qui dépasse la simple transaction commerciale. Un quartier sans petits commerces devient vite anonyme, voire impersonnel. Mon deuxième argument concerne la qualité et la proximité. Le boulanger du coin, le fromager, le primeur connaissent leurs produits, peuvent expliquer comment les cuisiner, et proposent souvent une qualité supérieure à celle des grandes surfaces. De plus, ces commerces étant à pied, on n'a pas besoin de prendre la voiture, ce qui est meilleur pour la santé et pour l'environnement. Cependant, je dois reconnaître que les supermarchés ont aussi leurs avantages. Ils sont souvent moins chers sur les produits du quotidien, ce qui n'est pas négligeable pour les budgets serrés, et offrent un choix beaucoup plus large. Une famille nombreuse peut difficilement faire toutes ses courses uniquement chez les commerçants de quartier. Pour conclure, je pense que la meilleure solution est de combiner les deux : faire ses gros achats au supermarché de temps en temps, mais privilégier les petits commerces pour le quotidien. C'est cette combinaison qui permet de garder un quartier vivant tout en respectant son budget.",
        "alternative_answer": "La question des petits commerces face aux supermarchés touche directement à la vie de nos quartiers. Personnellement, je pense que les deux sont nécessaires, mais que les petits commerces ont une utilité particulière qu'il ne faut pas sous-estimer. Premièrement, les petits commerces font vivre le quartier. Quand on a une boulangerie, un café et un primeur à proximité, le quartier est animé, on croise du monde, on se sent en sécurité. Cela améliore vraiment le sentiment d'appartenance à un lieu. Deuxièmement, ils offrent souvent des produits frais et locaux, ce qui est un vrai avantage en termes de qualité et d'impact écologique. Cependant, on ne peut pas nier les avantages des supermarchés. Ils permettent de tout acheter au même endroit, à des prix souvent plus bas, ce qui est essentiel pour beaucoup de familles. Sans eux, certains foyers auraient du mal à boucler le mois. Pour conclure, plutôt que d'opposer les deux, je pense qu'il faut les voir comme complémentaires. Préserver les petits commerces tout en gardant l'efficacité des grandes surfaces est, à mon avis, la meilleure formule pour un quartier équilibré.",
        "key_elements_to_cover": [
          "Position claire",
          "Argument lien social",
          "Argument qualité/proximité ou environnement",
          "Limite des petits commerces (prix/choix)",
          "Conclusion équilibrée"
        ],
        "key_vocabulary": ["petits commerces", "supermarché", "quartier", "lien social", "produits frais", "boulanger", "budget serré", "concurrence"],
        "key_grammar": ["Comparatifs", "Conditionnel", "Connecteurs (cependant, en revanche)", "Pronoms relatifs"]
      },
      "evaluation_focus": [
        "Position assumée",
        "Arguments différenciés (social ≠ qualité)",
        "Vocabulaire commercial et urbain",
        "Conclusion synthétique"
      ]
    },
    {
      "id": "q028",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Le vélo en ville est-il une vraie solution pour l'avenir ou seulement une mode ? Pourquoi ?",
      "themes": ["mobilité", "environnement", "ville"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position",
          "Argument environnement/santé",
          "Argument urbain (désengorgement, économie)",
          "Limites (météo, sécurité, distances)",
          "Conclusion"
        ],
        "reference_answer": "Depuis quelques années, le vélo a pris une place de plus en plus visible dans nos villes, avec des pistes cyclables, des vélos en libre-service et des subventions à l'achat. La question est de savoir si c'est une vraie solution durable ou simplement une mode passagère. Personnellement, je suis convaincu que le vélo est une solution d'avenir, à condition d'être bien intégré à une politique globale de mobilité. Mon premier argument concerne l'environnement et la santé. Le vélo ne consomme pas d'énergie fossile, ne pollue pas et ne fait pas de bruit. À l'échelle d'une ville, plus il y a de cyclistes, moins il y a de gaz à effet de serre et de particules fines. C'est aussi un excellent moyen de pratiquer une activité physique au quotidien, sans avoir besoin de prévoir un créneau spécifique pour le sport. Mon deuxième argument concerne l'organisation des villes. Le vélo prend beaucoup moins de place qu'une voiture, à la fois en circulation et en stationnement. Une ville qui développe le vélo respire mieux : il y a moins d'embouteillages, plus d'espaces partagés, et même les commerces de quartier en bénéficient, parce que les cyclistes s'arrêtent plus facilement pour acheter quelque chose en passant. Cependant, il faut reconnaître les limites. En cas de mauvais temps, sur de longues distances, ou pour les personnes âgées, le vélo n'est pas toujours une option. La sécurité reste aussi un vrai sujet : sans pistes cyclables séparées, beaucoup d'usagers n'osent pas se lancer. Pour conclure, je pense que le vélo n'est pas une mode, mais bien une réponse sérieuse aux défis urbains, climatiques et sanitaires. Il ne remplacera jamais entièrement la voiture ou les transports en commun, mais il en sera demain l'un des piliers essentiels.",
        "alternative_answer": "Le vélo s'est imposé dans nos villes ces dernières années. Effet de mode ou tendance durable ? Personnellement, je pense que le vélo est devenu une vraie solution d'avenir, même si certains défis restent à relever. Tout d'abord, il représente un moyen de transport propre, rapide pour les courtes distances, et bon pour la santé. Beaucoup de mes collègues qui sont passés au vélo électrique se déclarent moins stressés et en meilleure forme. Ensuite, il aide à désengorger les villes et à réduire la pollution sonore et atmosphérique, ce qui est essentiel à long terme. Cependant, il existe encore des freins importants. Il faut développer plus d'infrastructures sécurisées, parce que beaucoup de gens n'osent pas pédaler dans la circulation. Le vol des vélos est aussi un vrai problème dans certaines villes, ce qui décourage l'achat. Enfin, le vélo n'est pas adapté à tous : il faut tenir compte de la météo, des distances, et de la condition physique de chacun. Pour conclure, je dirais que le vélo n'est pas une mode passagère. C'est une solution sérieuse, mais qui doit s'inscrire dans une stratégie globale, avec d'autres modes de transport à côté.",
        "key_elements_to_cover": [
          "Position claire",
          "Argument écologique/santé",
          "Argument urbain",
          "Au moins une limite",
          "Conclusion réaliste"
        ],
        "key_vocabulary": ["mobilité", "piste cyclable", "vélo électrique", "embouteillages", "particules fines", "infrastructure", "désengorger", "tendance durable"],
        "key_grammar": ["Conditionnel", "Subjonctif", "Comparatifs", "Cause/conséquence"]
      },
      "evaluation_focus": [
        "Position assumée",
        "Arguments écologiques et urbains",
        "Vocabulaire de la mobilité",
        "Reconnaissance des limites"
      ]
    },
    {
      "id": "q029",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Les nouvelles technologies améliorent-elles vraiment la qualité des relations humaines ? Pourquoi ?",
      "themes": ["technologie", "relations humaines", "société"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position",
          "Argument positif (rapprocher, services)",
          "Argument négatif (distraction, superficialité)",
          "Nuance (usage)",
          "Conclusion"
        ],
        "reference_answer": "La question des nouvelles technologies et des relations humaines est très débattue aujourd'hui. À mon avis, elles n'améliorent pas automatiquement la qualité de nos relations, mais tout dépend de l'usage que l'on en fait. Mon premier argument est que ces technologies offrent de nouvelles possibilités de connexion. Les appels vidéo, les messages instantanés, les réseaux sociaux permettent de garder le contact avec des personnes éloignées, de retrouver d'anciens amis, ou de soutenir un proche en difficulté à des centaines de kilomètres de distance. Pour des familles séparées par la migration, par exemple, c'est un véritable changement par rapport à il y a vingt ans, où l'on ne pouvait s'écrire que par lettres rares. Mon deuxième argument va dans le sens contraire. Dans la vie quotidienne, on observe que ces mêmes technologies peuvent appauvrir nos relations directes. Combien de fois voit-on une famille au restaurant, chacun sur son téléphone, sans se parler ? Combien de couples qui consultent leurs notifications avant de se dire bonjour le matin ? Les conversations deviennent plus courtes, plus superficielles, parfois remplacées par de simples emojis. Il est vrai que tout dépend de la manière dont on utilise ces outils. Une personne qui les considère comme un complément à sa vie sociale en tirera des bénéfices. Une personne qui les laisse remplacer ses interactions réelles risque de s'isoler à long terme, sans même s'en rendre compte. Pour conclure, je dirais que les nouvelles technologies peuvent améliorer la qualité de nos relations à condition qu'elles soient utilisées avec discernement. Sinon, elles risquent de produire l'effet inverse : nous mettre en lien permanent avec tout le monde, mais nous priver de relations vraiment profondes.",
        "alternative_answer": "Les nouvelles technologies sont devenues omniprésentes dans nos vies, et leur impact sur les relations humaines est ambivalent. Personnellement, je pense qu'elles ont enrichi certains aspects de nos liens, mais qu'elles ont aussi affaibli d'autres dimensions essentielles. Premièrement, elles facilitent énormément le maintien du contact à distance. Pour les familles internationales, comme la mienne, pouvoir parler quotidiennement avec mes parents grâce à un simple appel vidéo est un cadeau qu'on aurait du mal à imaginer il y a quelques décennies. Deuxièmement, elles permettent de créer des communautés autour d'intérêts communs, ce qui est précieux pour les personnes isolées géographiquement. Cependant, on ne peut pas ignorer les effets négatifs. La surcharge de notifications, la pression de répondre immédiatement, la comparaison constante avec les vies idéalisées des autres pèsent lourd, surtout chez les jeunes. Pour conclure, les nouvelles technologies sont un outil puissant, mais elles ne suffisent pas à elles seules à améliorer nos relations. C'est notre manière de les utiliser, en gardant la priorité sur les rencontres réelles, qui fera la différence.",
        "key_elements_to_cover": [
          "Position claire",
          "Au moins un argument positif",
          "Au moins un argument critique",
          "Référence à des situations concrètes",
          "Conclusion nuancée"
        ],
        "key_vocabulary": ["nouvelles technologies", "appel vidéo", "réseaux sociaux", "superficialité", "isolement", "discernement", "notifications", "lien"],
        "key_grammar": ["Subjonctif après 'à condition que'", "Conditionnel", "Comparatifs", "Connecteurs"]
      },
      "evaluation_focus": [
        "Position personnelle",
        "Équilibre des arguments",
        "Vocabulaire technologique et social",
        "Capacité à nuancer"
      ]
    },
    {
      "id": "q030",
      "section": "expression_orale",
      "task_number": 3,
      "task_id": "oral_task_3",
      "task_type_fr": "Opinion / prise de position",
      "question": "Participer à une association locale est-il important pour bien vivre dans une ville ou un quartier ? Pourquoi ?",
      "themes": ["vie associative", "intégration", "communauté"],
      "timing": { "duration_minutes": 3.5, "preparation_minutes": 0 },
      "expected_response": {
        "word_count_target": { "min": 280, "ideal": 340, "max": 420 },
        "structure": [
          "Reformulation et position",
          "Argument lien social",
          "Argument utilité collective",
          "Nuance (toutes les formes valables)",
          "Conclusion personnelle"
        ],
        "reference_answer": "La vie associative occupe une place importante dans la culture française, mais on peut se demander si elle est vraiment nécessaire pour bien vivre dans son quartier. Personnellement, je suis convaincu que participer à une association locale est très bénéfique, à la fois pour soi-même et pour la collectivité, même s'il existe d'autres manières de s'intégrer. Mon premier argument concerne le lien social. Dans une ville, surtout pour quelqu'un qui vient d'arriver, il peut être difficile de rencontrer des gens en dehors du cadre du travail. Une association, qu'elle soit sportive, culturelle ou solidaire, offre un cadre régulier et bienveillant pour faire connaissance. On y rencontre des personnes de différents âges, de différents métiers, parfois de différentes origines, ce qui élargit notre vision des choses. Personnellement, c'est dans une association de randonnée que j'ai trouvé certains de mes meilleurs amis depuis mon installation. Mon deuxième argument concerne l'utilité collective. Beaucoup d'associations rendent des services concrets : aide aux devoirs, distribution de repas, soutien aux personnes âgées, animation de la vie de quartier. Quand on participe, on contribue à un quartier plus agréable et plus solidaire, et on en retire une vraie satisfaction personnelle. C'est aussi un excellent moyen de rester actif après la retraite. Cependant, je reconnais que toutes les associations ne sont pas adaptées à tout le monde. Certaines personnes préfèrent rendre service de manière plus informelle, en aidant un voisin ou en organisant des fêtes entre habitants. Cela peut tout aussi bien créer du lien. Pour conclure, je pense que la participation à une association locale est un excellent levier pour mieux vivre en ville. Mais l'essentiel, c'est surtout la disposition à s'ouvrir aux autres, sous une forme ou une autre.",
        "alternative_answer": "Participer à une association locale est-il important pour bien vivre dans une ville ? À mon avis, c'est très utile, mais ce n'est pas la seule manière de s'épanouir dans son quartier. Premier point : les associations permettent de rencontrer du monde et de se sentir intégré. Quand on s'investit dans un club ou une association, on tisse des liens qui dépassent le simple voisinage. C'est très précieux, surtout pour ceux qui viennent d'emménager ou qui ont peu de famille à proximité. Deuxième point : participer à une association donne du sens à son temps libre. Aider au soutien scolaire, organiser une fête de quartier ou planter des arbres avec une association environnementale apporte une vraie satisfaction et permet de transmettre des valeurs. Cependant, je pense qu'il faut nuancer. Tout le monde n'a pas le temps ou l'envie de s'engager dans une structure formelle. Certains préfèrent rendre service plus discrètement, ce qui est tout aussi respectable. Pour conclure, participer à une association n'est pas une obligation, mais c'est l'un des meilleurs moyens de bien vivre dans son quartier, parce que cela combine lien social, utilité et plaisir.",
        "key_elements_to_cover": [
          "Position claire",
          "Argument lien social",
          "Argument utilité ou sens",
          "Une nuance",
          "Conclusion personnelle"
        ],
        "key_vocabulary": ["association", "vie associative", "lien social", "bénévolat", "s'investir", "solidarité", "intégration", "sens"],
        "key_grammar": ["Conditionnel", "Subjonctif", "Comparatifs", "Connecteurs argumentatifs"]
      },
      "evaluation_focus": [
        "Position assumée",
        "Arguments distincts",
        "Vocabulaire de la vie collective",
        "Conclusion ouverte"
      ]
    },
    {
      "id": "q031",
