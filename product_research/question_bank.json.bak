    {
      "id": "q041",
      "section": "expression_ecrite",
      "task_number": 5,
      "task_id": "written_task_2",
      "task_type_fr": "Récit / expérience",
      "question": "Vous répondez à Malik. Vous lui racontez votre première journée dans un nouveau travail, un nouveau stage ou un nouveau cours de français.",
      "themes": ["travail", "expérience", "première fois"],
