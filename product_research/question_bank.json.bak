      "task_type_fr": "Texte d'opinion",
      "question": "Sur un site de parents et d'enseignants, vous expliquez s'il faut limiter le temps d'écran des enfants et des adolescents.",
      "themes": ["éducation", "écrans", "santé"],
      "channel": "site parents/enseignants",
      "register": "neutre à soutenu",
