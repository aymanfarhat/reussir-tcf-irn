      "task_id": "written_task_3",
      "task_type_fr": "Texte d'opinion",
      "question": "Sur un blog consacré au travail, vous dites si le télétravail quelques jours par semaine est une bonne idée, et vous justifiez votre opinion.",
      "themes": ["travail", "télétravail"],
      "channel": "blog professionnel",
      "register": "neutre à soutenu",
      "timing": { "suggested_duration_minutes": 12, "section_total_minutes": 30 },
