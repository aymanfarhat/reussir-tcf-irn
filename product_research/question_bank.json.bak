    {
      "id": "q044",
      "section": "expression_ecrite",
      "task_number": 5,
      "task_id": "written_task_2",
      "task_type_fr": "Récit / expérience",
      "question": "Vous répondez à Léo. Vous lui racontez une activité sportive ou de santé que vous avez commencée récemment et les effets que vous avez déjà remarqués.",
      "themes": ["santé", "sport", "bien-être"],
      "addressee": "Léo",
      "register": "informel (tu)",
      "timing": { "suggested_duration_minutes": 9, "section_total_minutes": 30 },
      "expected_response": {
        "word_count": { "min": 40, "max": 90, "target": 80 },
        "structure": [
          "Salutation à Léo",
          "Activité commencée + raison",
          "Fréquence et déroulement",
          "Effets déjà remarqués",
          "Bilan et invitation"
        ],
        "reference_answer": "Salut Léo,\nIl y a deux mois, j'ai commencé le yoga. J'avais souvent mal au dos à cause de mon travail assis. Maintenant, je vais à un cours d'une heure trois fois par semaine, le matin. C'est exigeant, mais j'ai déjà beaucoup moins de douleurs et je dors mieux. Je me sens aussi plus calme dans la journée. Tu devrais essayer ! Bisous, Camille.",
        "reference_answer_word_count": 65,
        "alternative_answer": "Coucou Léo,\nLe mois dernier, je me suis inscrit dans une salle de sport près de chez moi. J'y vais deux soirs par semaine après le travail. Les premières séances ont été très dures, j'avais des courbatures partout. Trois semaines plus tard, je me sens plus tonique, j'ai plus d'énergie et je dors profondément. Viens me rejoindre un soir ! Sami.",
        "alternative_answer_word_count": 60,
        "key_elements_to_cover": [
          "Activité identifiée",
          "Raison de la commencer",
          "Fréquence",
          "Au moins deux effets observés",
          "Conclusion ou invitation"
        ],
        "key_vocabulary": ["yoga", "salle de sport", "natation", "courbatures", "se sentir mieux", "énergie", "dormir", "tonique"],
        "key_grammar": ["Passé composé", "Imparfait pour 'avant'", "Présent pour 'maintenant'", "Comparatifs (mieux, plus)"]
      },
      "evaluation_focus": [
        "Effets concrets décrits",
        "Comparaison avant/maintenant",
        "Maîtrise des temps",
        "Compte de mots respecté"
      ]
    },
    {
      "id": "q045",
      "section": "expression_ecrite",
      "task_number": 5,
      "task_id": "written_task_2",
      "task_type_fr": "Récit / expérience",
      "question": "Vous répondez à Élise. Vous lui racontez un week-end ou une journée passée sans voiture, en expliquant comment vous vous êtes organisé(e).",
      "themes": ["mobilité", "vie quotidienne"],
