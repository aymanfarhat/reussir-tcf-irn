        "key_vocabulary": ["concert", "exposition", "spectacle", "musée", "ambiance", "spectateur", "magnifique", "impressionnant"],
        "key_grammar": ["Passé composé", "Imparfait", "Plus-que-parfait", "Adjectifs évaluatifs"]
      },
      "evaluation_focus": [
        "Description sensorielle",
        "Émotion exprimée",
        "Maîtrise des temps du passé",
