      "id": "q051",
      "section": "expression_ecrite",
      "task_number": 6,
      "task_id": "written_task_3",
      "task_type_fr": "Texte d'opinion",
      "question": "Sur un forum de quartier, vous expliquez si vous préférez faire vos courses dans les petits magasins ou au supermarché, et vous dites pourquoi.",
      "themes": ["consommation", "vie de quartier"],
      "channel": "forum de quartier",
      "register": "neutre, opinionné mais courtois",
      "timing": { "suggested_duration_minutes": 12, "section_total_minutes": 30 },
      "expected_response": {
        "word_count": { "min": 40, "max": 90, "target": 85 },
